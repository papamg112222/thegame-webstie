function openShop(){
  document.getElementById('shopOL').classList.add('open');
  document.getElementById('shop-coins').textContent=gs.coins;
  document.getElementById('shop-coins2').textContent=gs.coins;
  renderShopContent();
}
function closeShop(){ document.getElementById('shopOL').classList.remove('open'); }
 
function switchTab(tab, btn){
  shopTab=tab;
  document.querySelectorAll('.shop-tab').forEach(t=>t.classList.remove('active'));
  btn.classList.add('active');
  renderShopContent();
}
 
function renderShopContent(){
  const cont=document.getElementById('shop-content');
  cont.innerHTML='';
  const items=SHOP_DATA[shopTab];
  for(const item of items){
    const lv=gs.upgrades[item.id]||0;
    const maxed=lv>=item.maxLevel;
    const cost=Math.round(item.baseCost*Math.pow(1.85,lv));
    const canBuy=gs.coins>=cost&&!maxed;
 
    const el=document.createElement('div');
    el.className='s-item'+(maxed?' maxed':'');
 
    // Icon canvas
    const ic=document.createElement('canvas');
    ic.width=48; ic.height=48; ic.className='s-icon';
    drawShopIcon(ic,item.icon);
 
    el.appendChild(ic);
    el.innerHTML+=`
      <div class="s-name">${item.name}</div>
      <div class="s-desc">${item.desc}</div>
      <div class="s-pips">${Array.from({length:item.maxLevel},(_,i)=>`<div class="s-pip${i<lv?' on':''}"></div>`).join('')}</div>
      <button class="s-buy" onclick="buyUpgrade('${item.id}')" ${canBuy?'':'disabled'}>${maxed?'MAXED':'BUY '+cost+' FC'}</button>
    `;
    cont.appendChild(el);
  }
}
 
function buyUpgrade(id){
  let item;
  for(const tab of Object.values(SHOP_DATA)){item=tab.find(i=>i.id===id);if(item)break;}
  if(!item) return;
  const lv=gs.upgrades[id]||0;
  const cost=Math.round(item.baseCost*Math.pow(1.85,lv));
  if(gs.coins<cost){showNotif('NOT ENOUGH FLESH COINS!','#f44');return;}
  if(lv>=item.maxLevel) return;
  gs.coins-=cost;
  gs.upgrades[id]=lv+1;
  applyUpgrade(id,lv+1,item);
  showNotif('BOUGHT: '+item.name+' LV '+(lv+1),'#0f8');
  document.getElementById('shop-coins').textContent=gs.coins;
  document.getElementById('shop-coins2').textContent=gs.coins;
  renderShopContent();
}
 
function applyUpgrade(id,lv,item){
  switch(id){
    case 'fins':    gs.swimSpeed=2.2+lv*0.55; break;
    case 'weight':  gs.sinkSpeed=2.5+lv*0.65; break;
    case 'suit':    gs.maxDepth=600+lv*800; break;
    case 'hook':    gs.catchRadius=90+lv*20; break;
    case 'net1':    gs.maxNet+=5; break;
    case 'net2':    gs.maxNet+=10; break;
    case 'net3':    gs.maxNet+=20; break;
    case 'net4':    gs.maxNet+=50; break;
    case 'tank1':   gs.maxOxy+=30; gs.curOxy=gs.maxOxy; break;
    case 'tank2':   gs.maxOxy+=90; gs.curOxy=gs.maxOxy; break;
    case 'tank3':   gs.maxOxy+=180; gs.curOxy=gs.maxOxy; break;
    case 'tank4':   gs.maxOxy+=600; gs.curOxy=gs.maxOxy; break;
    case 'swim1':   gs.swimBoost=1+lv*0.32; break;
    case 'luck1':   gs.luck=Math.min(80,gs.luck+12); break;
    case 'luck2':   gs.luck=Math.min(95,gs.luck+20); break;
    case 'luck3':   gs.luckMythic+=1; break;
    case 'luck4':   gs.valueBoost=1.5; break;
  }
}
 
