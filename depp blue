function showBeastMsg(fish, scale, depthM){
  const sizeName = scale>=8?'COLOSSAL':scale>=5?'GIANT':scale>=3?'LARGE':'BIG';
  beastMsg = {
    fish,
    scale: scale.toFixed(1),
    sizeName,
    depth: depthM,
    text1: `⚠ A ${sizeName} ${fish.name.toUpperCase()} HAS AWAKENED`,
    text2: `at ${depthM.toLocaleString()}m depth — CATCH IT BEFORE IT FLEES!`,
    col: fish.glow || RARITY_COL[fish.rarity],
  };
  beastMsgTimer = 6; // seconds on screen
}
 
function spawnFish(forceFish, forceScale, forceDepth){
  if(!forceFish && liveFish.length>14) return;
  const dm = forceDepth !== undefined ? forceDepth : worldDepthM();
  let chosen;
  if(forceFish){
    chosen=forceFish;
  } else {
    const cands=FISH.filter(f=> dm>=(f.depth[0]-300) && dm<=(f.depth[1]+300));
    const pool=cands.length ? cands : FISH.filter(f=>f.rarity===0);
    const depthT=Math.min(1, dm/8000);
    const rarW=[
      Math.max(0, 1.0-depthT*1.3),
      Math.max(0, 0.5-depthT*0.4),
      Math.min(1, 0.1+depthT*0.9),
      Math.min(1, depthT*depthT*1.2),
      Math.min(1, Math.max(0,(depthT-0.4)*1.5)),
      Math.min(1, Math.max(0,(depthT-0.6)*2.0)),
    ];
    const luck=gs.luck/100;
    const wts=pool.map(f=>{
      let w=rarW[f.rarity];
      w+=luck*0.25*(f.rarity/5);
      w+=gs.luckMythic*0.08*(f.rarity>=4?1:0);
      return Math.max(0.001, w);
    });
    const tot=wts.reduce((a,b)=>a+b,0);
    let r=Math.random()*tot; chosen=pool[0];
    for(let i=0;i<pool.length;i++){r-=wts[i];if(r<=0){chosen=pool[i];break;}}
  }
 
  const side=Math.random()<0.5;
  let baseScale;
  if(forceScale!==undefined){
    baseScale=Math.max(0.1, forceScale);
  } else {
    const rarMin=[0.7,1.0,1.5,2.0,2.8,3.5][chosen.rarity];
    const rarMax=[1.8,2.2,2.8,3.5,4.5,6.0][chosen.rarity];
    baseScale=rarMin+Math.random()*(rarMax-rarMin);
  }
 
  // Bigger fish swim MUCH slower — massive ones are almost majestic/slow
  // scale 1 = normal speed, scale 3 = half speed, scale 6 = quarter speed
  const spd = (0.35 + Math.random()*0.55) / Math.max(1, baseScale*0.55);
 
  // Beast announcement for scale >= 3.0
  if(baseScale >= 3.0){
    const spawnDepth = forceDepth !== undefined ? forceDepth : dm;
    showBeastMsg(chosen, baseScale, spawnDepth);
  }
 
  // If forceDepth, spawn diver's visible area; otherwise use camera
  const spawnWorldY = (camY + SURF_Y + 70 + Math.random()*(H-SURF_Y-120));
  liveFish.push({
    fish: chosen, x: side?-120:W+120, y: spawnWorldY,
    vx: side?spd:-spd, vy: (Math.random()-0.5)*0.15,
    phase: Math.random()*Math.PI*2, t: Math.random()*100,
    caught: false, scale: baseScale,
  });
}
 
