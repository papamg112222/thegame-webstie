    // Size multiplier: exponential — big fish worth massively more
    const sizeMult = Math.pow(sc, 1.8);
    const val = Math.round(c.fish.value * sizeMult * gs.valueBoost);
    total += val;
 
    const sizeLabel = sc >= 5 ? '👑 COLOSSAL' : sc >= 4 ? '🔥 GIANT' : sc >= 2.5 ? '⬆ BIG' : sc >= 1.5 ? '↑ LARGE' : '';
