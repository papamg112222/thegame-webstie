  ctx.shadowColor=C(lureGlow); ctx.shadowBlur=18*s;
  pxArc(ctx,-12*s,(-18-lureY)*s,4*s,4*s,lureGlow);
  pxArc(ctx,-12*s,(-18-lureY)*s,2*s,2*s,P(255,255,255,240));
  ctx.shadowBlur=0;
  // Illicium (lure stalk) — curved
  for(let i=0;i<6;i++) pxRect(ctx,(-11+i)*s,(-14-lureY+i*1.5)*s,s,s,fin);
  // Huge globose body
  pxArc(ctx,0,0,13*s,12*s,body);
  pxArc(ctx,-2*s,-3*s,10*s,9*s,b2);
  pxArc(ctx,2*s,4*s,10*s,7*s,b3);
  // Bioluminescent patches on body
  ctx.shadowColor='rgba(100,200,255,0.4)'; ctx.shadowBlur=6*s;
  pxArc(ctx,5*s,-5*s,2*s,2*s,P(0,180,255,120));
  pxArc(ctx,-3*s,6*s,2*s,2*s,P(0,180,255,100));
  ctx.shadowBlur=0;
  // Fleshy dorsal fin (photophores)
  pxRect(ctx,1*s,-14*s,6*s,4*s,fin);
  pxRect(ctx,3*s,-12*s,4*s,3*s,lighter(fin,20));
  // Pectoral fins (arm-like)
  pxRect(ctx,-13*s,-2*s,5*s,6*s,fin);
  pxRect(ctx,8*s,-2*s,5*s,6*s,fin);
  // Tail
  const wag=Math.sin(t*2)*s*2;
  pxRect(ctx,13*s+wag,-8*s,7*s,7*s,fin);
  pxRect(ctx,13*s+wag, 2*s,7*s,7*s,fin);
  pxRect(ctx,16*s+wag,-5*s,4*s,10*s,lighter(fin,15));
  // Massive jaw — upper
  pxRect(ctx,-16*s,-5*s,10*s,6*s,b2);
  pxRect(ctx,-18*s,-3*s,4*s,4*s,b2);
  // Lower jaw (articulates)
  pxRect(ctx,-16*s, jawGape,10*s,6*s,b2);
  // Teeth — upper (long, fang-like)
  for(let i=0;i<5;i++) pxRect(ctx,(-15+i*3)*s,-4*s,s*1.5,5*s,P(240,240,220));
  // Teeth — lower
  for(let i=0;i<4;i++) pxRect(ctx,(-14+i*3)*s, jawGape+2*s,s*1.5,4*s,P(230,230,210));
  // Gum tissue
  pxRect(ctx,-16*s,-4*s,10*s,2*s,P(160,40,40));
  pxRect(ctx,-16*s, jawGape+2*s,10*s,2*s,P(160,40,40));
  // Eyes — huge, bulging, bioluminescent
  ctx.shadowColor='rgba(200,0,200,0.6)'; ctx.shadowBlur=8*s;
  pxArc(ctx,-8*s,-6*s,6*s,6*s,P(180,0,180,200));
  ctx.shadowBlur=0;
  pxArc(ctx,-8*s,-6*s,4*s,4*s,P(0,0,0));
  pxRect(ctx,-10*s,-8*s,2*s,2*s,P(255,200,255,200));
  // Secondary photophore row along lateral
  ctx.shadowColor='rgba(0,200,255,0.5)'; ctx.shadowBlur=4*s;
  for(let i=0;i<4;i++) pxRect(ctx,(-4+i*4)*s,3*s,s,s,P(0,200,255,160));
