function refreshAdminCmds(query){
  const q=query.toLowerCase();
  const filtered=q
    ? ADMIN_CMDS.filter(c=>c.cmd.toLowerCase().includes(q)||c.desc.toLowerCase().includes(q))
    : ADMIN_CMDS;
  const list=document.getElementById('ac-cmd-list');
  list.innerHTML='';
  for(const c of filtered){
    const row=document.createElement('div');
    row.className='ac-cmd-row';
    // Highlight matching part
    let cmdHtml=c.cmd;
    if(q) cmdHtml=c.cmd.replace(new RegExp(q.replace(/[.*+?^${}()|[\]\\]/g,'\\$&'),'gi'),m=>`<span style="color:#fff;background:rgba(255,215,0,0.2)">${m}</span>`);
    row.innerHTML=`<span class="ac-cmd-text">${cmdHtml}</span><span class="ac-cmd-desc">${c.desc}</span>`;
    row.onclick=()=>{
      const filled=c.cmd.replace(/\{[^}]+\}/,'');
      document.getElementById('ac-input').value=filled;
      document.getElementById('ac-input').focus();
      onAdminInput();
    };
    list.appendChild(row);
  }
}
 
function refreshFishList(query){
  const q=(query||'').toLowerCase();
  const filtered=q ? FISH.filter(f=>f.name.toLowerCase().includes(q)) : FISH;
  const list=document.getElementById('ac-fish-list');
