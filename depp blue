<script>
// ═══════════════════════════════════════════════════════
//  PIXEL PALETTE & DRAW UTILITIES
// ═══════════════════════════════════════════════════════
const P = (r,g,b,a=255)=>[r,g,b,a];
const C = (arr)=>`rgba(${arr[0]},${arr[1]},${arr[2]},${(arr[3]??255)/255})`;
function pxRect(ctx,x,y,w,h,col){ctx.fillStyle=C(col);ctx.fillRect(Math.floor(x),Math.floor(y),Math.ceil(w),Math.ceil(h));}
function pxLine(ctx,x1,y1,x2,y2,col,lw=1){
  ctx.strokeStyle=C(col);ctx.lineWidth=lw;
  ctx.beginPath();ctx.moveTo(Math.floor(x1)+.5,Math.floor(y1)+.5);
  ctx.lineTo(Math.floor(x2)+.5,Math.floor(y2)+.5);ctx.stroke();
}
function pxCirc(ctx,x,y,r,col){ctx.fillStyle=C(col);ctx.beginPath();ctx.arc(Math.floor(x),Math.floor(y),r,0,Math.PI*2);ctx.fill();}
 
// Lighten/darken a colour
const lighter=(c,amt)=>P(Math.min(255,c[0]+amt),Math.min(255,c[1]+amt),Math.min(255,c[2]+amt),c[3]);
const darker =(c,amt)=>P(Math.max(0,c[0]-amt),Math.max(0,c[1]-amt),Math.max(0,c[2]-amt),c[3]);
 
// ═══════════════════════════════════════════════════════
//  RARITY SYSTEM
// ═══════════════════════════════════════════════════════
const RARITY_COL  = ["#aaaaaa","#44cc66","#4499ff","#cc44ff","#ffaa00","#ff2244"];
const RARITY_NAME = ["Common","Uncommon","Rare","Epic","Legendary","Mythic"];
// Size multiplier per rarity — bigger fish for rarer finds
const RARITY_SCALE = [1.0, 1.4, 1.9, 2.6, 3.4, 4.5];
 
// ═══════════════════════════════════════════════════════
//  DETAILED PIXEL FISH DRAW FUNCTIONS
//  Every fish is drawn at base scale=1 then scaled by RARITY_SCALE[rarity]
// ═══════════════════════════════════════════════════════
 
function applyGlow(ctx,col,intensity){ctx.shadowColor=col;ctx.shadowBlur=intensity;}
 
// ── Smooth arc helper ──
function pxArc(ctx,cx,cy,rx,ry,col,filled=true){
  ctx.beginPath();
  ctx.ellipse(Math.floor(cx),Math.floor(cy),Math.max(1,rx),Math.max(1,ry),0,0,Math.PI*2);
  if(filled){ctx.fillStyle=C(col);ctx.fill();}
  else{ctx.strokeStyle=C(col);ctx.stroke();}
}
 
// ─────────────────────────────────────────────────────────────────
// SMALL SCHOOLING FISH (sardine, herring, goby) — detailed silver body
// ─────────────────────────────────────────────────────────────────
function drawSmall(ctx,s,t,body,fin){
  const w=Math.sin(t*5)*s*1.8, b2=lighter(body,40), b3=darker(body,25);
  // Forked tail with detail
  pxRect(ctx,6*s+w,-4*s,5*s,3*s,fin);
  pxRect(ctx,6*s+w, 1*s,5*s,3*s,fin);
  pxRect(ctx,8*s+w,-2*s,2*s,4*s,lighter(fin,30));
  // Body — tapered torpedo
  pxRect(ctx,-7*s,-4*s,15*s,8*s,body);
  pxRect(ctx,-5*s,-5*s,10*s,2*s,body);
  pxRect(ctx,-5*s, 3*s,10*s,2*s,body);
  pxRect(ctx,-8*s,-3*s,2*s,6*s,b2); // head bump
  // Lateral line (iridescent stripe)
  pxRect(ctx,-6*s,-1*s,13*s,2*s,b2);
  pxRect(ctx,-4*s,-1*s,10*s,1*s,P(200,220,255,140));
  // Dorsal fin
  pxRect(ctx,-2*s,-7*s,6*s,3*s,fin);
  pxRect(ctx,-1*s,-6*s,4*s,2*s,lighter(fin,20));
  // Pectoral fin (semi-transparent)
  pxRect(ctx,-2*s, 3*s,5*s,3*s,P(fin[0],fin[1],fin[2],160));
  // Belly lighter
  pxRect(ctx,-6*s, 1*s,12*s,2*s,b2);
  // Head + eye
  pxRect(ctx,-9*s,-3*s,4*s,6*s,b2);
  pxRect(ctx,-11*s,-1*s,3*s,3*s,lighter(b2,20)); // snout
  pxRect(ctx,-8*s,-2*s,3*s,3*s,P(255,255,255));
  pxRect(ctx,-7*s,-1*s,2*s,2*s,P(10,10,20));
  pxRect(ctx,-8*s,-2*s,1*s,1*s,P(255,255,255,200)); // eye shine
  // Scale pattern
  for(let i=0;i<3;i++){
    pxRect(ctx,(-4+i*4)*s,-4*s,2*s,1*s,P(255,255,255,40));
  }
}
 
// ─────────────────────────────────────────────────────────────────
// STANDARD FISH — detailed torpedo with gill lines + iridescence
// ─────────────────────────────────────────────────────────────────
function drawStandard(ctx,s,t,body,fin,belly){
  const w=Math.sin(t*3.5)*s*2.5, b2=lighter(body,35), b3=darker(body,30);
  belly=belly||lighter(body,55);
  // Forked tail
  pxRect(ctx,11*s+w,-6*s,8*s,5*s,fin);
  pxRect(ctx,11*s+w, 1*s,8*s,5*s,fin);
  pxRect(ctx,14*s+w,-4*s,4*s,8*s,lighter(fin,25));
  // Caudal peduncle (narrow before tail)
  pxRect(ctx,8*s,-3*s,5*s,6*s,b3);
  // Body
  pxRect(ctx,-10*s,-6*s,20*s,12*s,body);
  pxRect(ctx,-7*s,-8*s,16*s,4*s,body);
  pxRect(ctx,-7*s, 4*s,16*s,4*s,body);
  // Dorsal shading gradient
  pxRect(ctx,-8*s,-6*s,17*s,2*s,b3);
  pxRect(ctx,-5*s,-4*s,14*s,2*s,b2);
  // Belly
  pxRect(ctx,-8*s, 2*s,17*s,4*s,belly);
  pxRect(ctx,-6*s, 4*s,13*s,2*s,lighter(belly,20));
  // Lateral line
  pxRect(ctx,-9*s,-1*s,18*s,2*s,P(b2[0],b2[1]+10,b2[2]+20,180));
  // Dorsal fin (multi-ray)
  pxRect(ctx,-3*s,-12*s,10*s,4*s,fin);
  pxRect(ctx,-1*s,-11*s,8*s,3*s,lighter(fin,20));
  for(let i=0;i<4;i++) pxRect(ctx,(-2+i*2)*s,-11*s,1*s,4*s,darker(fin,20));
  // Anal fin
  pxRect(ctx, 2*s, 8*s,6*s,4*s,fin);
  // Pectoral fin
  pxRect(ctx,-5*s, 4*s,9*s,6*s,P(fin[0],fin[1],fin[2],180));
  pxRect(ctx,-4*s, 5*s,7*s,4*s,lighter(P(fin[0],fin[1],fin[2],180),20));
  // Head
  pxRect(ctx,-15*s,-5*s,7*s,10*s,b2);
  pxRect(ctx,-18*s,-3*s,5*s,7*s,b2);
  // Mouth
  pxRect(ctx,-19*s, 0*s,2*s,2*s,darker(b2,40));
  // Gill slit
  pxLine(ctx,-11*s,-6*s,-11*s,6*s,b3,s*2);
  pxLine(ctx,-9*s,-5*s,-9*s,5*s,b3,s);
  // Eye — detailed
  pxRect(ctx,-13*s,-4*s,5*s,5*s,P(255,255,255));
  pxRect(ctx,-12*s,-3*s,3*s,3*s,P(15,15,30));
  pxRect(ctx,-11*s,-4*s,1*s,1*s,P(255,255,255,220));
  pxRect(ctx,-13*s,-4*s,1*s,1*s,P(200,200,255,100)); // iris rim
  // Scale dots
  for(let r=0;r<3;r++) for(let c=0;c<4;c++){
    pxRect(ctx,(-6+c*4)*s,(-4+r*3)*s,2*s,2*s,P(255,255,255,25));
  }
}
 
// ─────────────────────────────────────────────────────────────────
// ROUND FISH — pufferfish with spines and face detail
// ─────────────────────────────────────────────────────────────────
function drawRound(ctx,s,t,body,fin,spikes){
  const w=Math.sin(t*2.5)*s*1.5, b2=lighter(body,30), b3=darker(body,25), belly=lighter(body,50);
  // Tail — fan shape
  pxRect(ctx,11*s+w,-5*s,7*s,10*s,fin);
  pxRect(ctx,13*s+w,-3*s,4*s,6*s,lighter(fin,25));
  // Round body
  pxArc(ctx,0,0,11*s,10*s,body);
  pxArc(ctx,-1*s,-1*s,8*s,7*s,b2);
  pxArc(ctx,0,3*s,9*s,5*s,belly);
  pxArc(ctx,-2*s,-4*s,5*s,4*s,lighter(b2,20));
  // Patterning/spots
  pxArc(ctx,-4*s,-3*s,2*s,2*s,darker(body,15));
  pxArc(ctx,2*s,-5*s,2*s,2*s,darker(body,15));
  pxArc(ctx,5*s,0*s,2*s,2*s,darker(body,15));
  pxArc(ctx,-3*s,4*s,2*s,2*s,darker(body,15));
  // Spines
  if(spikes){
    const pts=[[-10,-8],[-4,-11],[3,-11],[9,-7],[11,-2],[10,5],[4,10],[-3,10],[-9,6],[-11,0]];
    for(const [px,py] of pts){
      pxRect(ctx,px*s-s,py*s-s,2*s,2*s,lighter(fin,30));
      pxRect(ctx,px*s,py*s,s,s,P(255,255,220));
    }
  }
  // Dorsal fin
  pxRect(ctx,-4*s,-13*s,9*s,4*s,fin);
  // Pectoral fins
  pxRect(ctx,-12*s,-3*s,4*s,7*s,P(fin[0],fin[1],fin[2],180));
  // Face
  pxRect(ctx,-13*s,-4*s,6*s,8*s,b2);
  // Big cute eye
  pxArc(ctx,-10*s,-2*s,4*s,4*s,P(255,255,255));
  pxArc(ctx,-10*s,-2*s,2.5*s,2.5*s,P(20,10,40));
  pxRect(ctx,-11*s,-3*s,1*s,1*s,P(255,255,255,220));
  // Mouth (pursed)
  pxRect(ctx,-15*s,2*s,3*s,2*s,darker(b2,50));
}
function drawRoundPlain(ctx,s,t,body,fin){drawRound(ctx,s,t,body,fin,false);}
 
// ─────────────────────────────────────────────────────────────────
// EEL — sinuous with detailed scales and fins
// ─────────────────────────────────────────────────────────────────
function drawEel(ctx,s,t,body,fin){
  const segs=10, b2=lighter(body,25), b3=darker(body,30);
  const belly=lighter(body,45);
  // Body segments — sinuous wave
  for(let i=0;i<segs;i++){
    const ox=(-segs/2+i)*5.2*s;
    const oy=Math.sin(t*2.5+i*0.65)*5*s;
    const h=i===0?8*s:i===segs-1?3*s:6*s;
    const segW=5*s;
    // Scale gradient
    pxRect(ctx,ox,oy-h/2,segW,h,i%2===0?body:b2);
    pxRect(ctx,ox,oy-h/2,segW,Math.ceil(h*0.25),b3); // dorsal dark
    pxRect(ctx,ox,oy+h/2-Math.ceil(h*0.2),segW,Math.ceil(h*0.2),belly); // belly
    // Scale lines
    if(i>0&&i<segs-1) pxRect(ctx,ox+s,oy-h/4,s,h/2,P(255,255,255,20));
    // Dorsal fin along entire body
    if(i>0&&i<segs-1){
      pxRect(ctx,ox+s,oy-h/2-3*s,3*s,3*s,P(fin[0],fin[1],fin[2],180));
    }
    // Ventral fin
    if(i>1&&i<segs-2){
      pxRect(ctx,ox+s,oy+h/2,3*s,2*s,P(fin[0],fin[1],fin[2],140));
    }
  }
  // Tail fin
  const tx=(-segs/2+segs-1)*5.2*s;
  const ty=Math.sin(t*2.5+(segs-1)*0.65)*5*s;
  const tw=Math.sin(t*3)*s*2.5;
  pxRect(ctx,tx+5*s+tw,-5*s,5*s,5*s,fin);
  pxRect(ctx,tx+5*s+tw,0,5*s,5*s,fin);
  pxRect(ctx,tx+6*s+tw,-3*s,3*s,6*s,lighter(fin,20));
  // Head — detailed
  const hx=(-segs/2)*5.2*s-6*s;
  const hy=Math.sin(t*2.5)*5*s;
  pxRect(ctx,hx,hy-5*s,8*s,10*s,lighter(b2,15));
  pxRect(ctx,hx-5*s,hy-2*s,6*s,5*s,lighter(b2,15)); // jaw
  // Upper teeth
  for(let i=0;i<3;i++) pxRect(ctx,(hx-4+i*2)*s,hy-2*s,s,3*s,P(240,240,220));
  // Head fin
  pxRect(ctx,hx,hy-8*s,2*s,8*s,fin);
  // Nostrils
  pxRect(ctx,hx-3*s,hy-3*s,s,s,darker(b2,50));
  // Eye
  pxRect(ctx,hx+2*s,hy-4*s,4*s,4*s,P(255,220,0));
  pxRect(ctx,hx+3*s,hy-3*s,2*s,2*s,P(0,0,0));
  pxRect(ctx,hx+2*s,hy-4*s,1*s,1*s,P(255,255,255,200));
}
 
// ─────────────────────────────────────────────────────────────────
// RAY / MANTA — winged with detailed patterning
// ─────────────────────────────────────────────────────────────────
function drawRay(ctx,s,t,body,fin){
  const wag=Math.sin(t*2)*s*4, wingFlap=Math.sin(t*1.8)*s*3;
  const b2=lighter(body,20), b3=darker(body,35), belly=lighter(body,55);
  // Left wing (back, darker)
  ctx.save();
  ctx.translate(-18*s,wingFlap);
  ctx.rotate(-0.15+wingFlap*0.01);
  pxRect(ctx,-14*s,-5*s,14*s,10*s,b3);
  pxRect(ctx,-20*s,-3*s,8*s,6*s,b3);
  pxRect(ctx,-25*s,-1*s,6*s,3*s,darker(b3,20));
  // Wing pattern
  for(let i=0;i<5;i++) pxRect(ctx,(-19+i*3)*s,-3*s,s,6*s,P(b3[0]+15,b3[1]+15,b3[2]+15,120));
  ctx.restore();
  // Right wing
  ctx.save();
  ctx.translate(18*s,-wingFlap);
  ctx.rotate(0.15-wingFlap*0.01);
  pxRect(ctx,0,-5*s,14*s,10*s,b3);
  pxRect(ctx,12*s,-3*s,8*s,6*s,b3);
  pxRect(ctx,19*s,-1*s,6*s,3*s,darker(b3,20));
  for(let i=0;i<5;i++) pxRect(ctx,(2+i*3)*s,-3*s,s,6*s,P(b3[0]+15,b3[1]+15,b3[2]+15,120));
  ctx.restore();
  // Central body disk
  pxArc(ctx,0,0,14*s,8*s,body);
  pxArc(ctx,-2*s,-2*s,10*s,6*s,b2);
  pxArc(ctx,0,2*s,12*s,5*s,belly);
  // Dorsal spots (manta pattern)
  pxRect(ctx,-6*s,-5*s,4*s,3*s,P(255,255,255,30));
  pxRect(ctx,2*s,-5*s,4*s,3*s,P(255,255,255,30));
  // Spiracle (openings)
  pxRect(ctx,-8*s,-4*s,2*s,2*s,darker(body,60));
  pxRect(ctx,6*s,-4*s,2*s,2*s,darker(body,60));
  // Head/cephalic fins (horns)
  pxRect(ctx,-15*s,-3*s,6*s,4*s,b2);
  pxRect(ctx,-19*s,-1*s,5*s,3*s,b2);
  pxRect(ctx,9*s,-3*s,6*s,4*s,b2);
  // Eyes
  pxRect(ctx,-10*s,-5*s,3*s,3*s,P(255,255,255));
  pxRect(ctx,-9*s,-4*s,2*s,2*s,P(0,0,0));
  pxRect(ctx,7*s,-5*s,3*s,3*s,P(255,255,255));
  pxRect(ctx,8*s,-4*s,2*s,2*s,P(0,0,0));
  // Long tail with stinger
  pxRect(ctx,14*s+wag,-2*s,22*s,3*s,fin);
  pxRect(ctx,20*s+wag,-4*s,3*s,7*s,P(60,60,80)); // stinger
  pxRect(ctx,22*s+wag,-5*s,2*s,3*s,P(200,200,220));
  // Gill slits on belly
  for(let g=0;g<5;g++) pxRect(ctx,(-4+g*2)*s,4*s,s,3*s,darker(belly,30));
}
 
// ─────────────────────────────────────────────────────────────────
// SHARK — apex predator with full anatomy
// ─────────────────────────────────────────────────────────────────
function drawShark(ctx,s,t,body,fin){
  const wag=Math.sin(t*2.2)*s*4, b2=lighter(body,18), b3=darker(body,22), belly=lighter(body,55);
  // Crescent tail — detailed
  pxRect(ctx,15*s+wag,-10*s,9*s,9*s,fin);
  pxRect(ctx,15*s+wag, 2*s,9*s,9*s,fin);
  pxRect(ctx,18*s+wag,-6*s,5*s,12*s,lighter(fin,18));
  pxRect(ctx,20*s+wag,-4*s,3*s,8*s,lighter(fin,30));
  // Caudal peduncle
  pxRect(ctx,11*s,-4*s,6*s,8*s,b3);
  // Main body — torpedo
  pxRect(ctx,-16*s,-7*s,30*s,14*s,body);
  pxRect(ctx,-12*s,-10*s,24*s,6*s,body);
  pxRect(ctx,-12*s, 4*s,24*s,6*s,body);
  pxRect(ctx,-18*s,-5*s,5*s,10*s,body);
  // Counter-shading
  pxRect(ctx,-16*s,-7*s,28*s,3*s,b3); // dark back
  pxRect(ctx,-14*s,-4*s,25*s,3*s,b2); // mid highlight
  pxRect(ctx,-14*s, 2*s,26*s,5*s,belly); // white belly
  pxRect(ctx,-12*s, 5*s,22*s,3*s,lighter(belly,20));
  // Lateral line
  pxRect(ctx,-15*s,-1*s,27*s,s,P(b2[0],b2[1],b2[2]+10,160));
  // Dorsal fin — iconic tall
  pxRect(ctx,0,-18*s,10*s,10*s,fin);
  pxRect(ctx,2*s,-16*s,7*s,8*s,lighter(fin,15));
  pxRect(ctx,4*s,-14*s,4*s,5*s,lighter(fin,30));
  // Second dorsal
  pxRect(ctx,8*s,-11*s,5*s,6*s,fin);
  // Pectoral fins (large)
  pxRect(ctx,-8*s,6*s,16*s,8*s,fin);
  pxRect(ctx,-6*s,7*s,12*s,6*s,lighter(fin,15));
  // Pelvic fins
  pxRect(ctx,4*s,7*s,7*s,5*s,fin);
  // Anal fin
  pxRect(ctx,9*s,7*s,5*s,4*s,fin);
  // Head — blunt
  pxRect(ctx,-21*s,-6*s,7*s,12*s,b2);
  pxRect(ctx,-25*s,-3*s,6*s,7*s,b2); // snout
  // Mouth (open, rows of teeth)
  pxRect(ctx,-24*s, 2*s,7*s,3*s,P(40,15,15)); // mouth interior
  for(let i=0;i<5;i++) pxRect(ctx,(-23+i*2)*s,0,s,4*s,P(240,240,220)); // upper teeth
  for(let i=0;i<4;i++) pxRect(ctx,(-22+i*2)*s,2*s,s,3*s,P(230,230,210)); // lower teeth
  // Nostrils
  pxRect(ctx,-22*s,-4*s,2*s,s,darker(b2,40));
  pxRect(ctx,-19*s,-4*s,2*s,s,darker(b2,40));
  // Gill slits (5)
  for(let g=0;g<5;g++) pxLine(ctx,(-15+g*3)*s,-7*s,(-15+g*3)*s,7*s,b3,s*1.5);
  // Eye — black with white highlight
  pxRect(ctx,-17*s,-5*s,6*s,6*s,P(255,255,255));
  pxRect(ctx,-15*s,-4*s,4*s,4*s,P(5,5,15));
  pxRect(ctx,-17*s,-5*s,2*s,2*s,P(255,255,255,200));
  pxRect(ctx,-15*s,-5*s,2*s,s,P(200,180,220,120)); // nictitating membrane tinge
}
 
// ─────────────────────────────────────────────────────────────────
// ANGEL FISH — tall, elegant, disc-shaped
// ─────────────────────────────────────────────────────────────────
function drawAngel(ctx,s,t,body,fin){
  const wag=Math.sin(t*2.5)*s*2.5, b2=lighter(body,30), b3=darker(body,30), belly=lighter(body,50);
  // Tail streamers (long, flowing)
  pxRect(ctx,9*s+wag,-10*s,7*s,8*s,fin);
  pxRect(ctx,9*s+wag, 2*s,7*s,8*s,fin);
  pxRect(ctx,11*s+wag,-7*s,4*s,14*s,lighter(fin,25));
  // Lower trailing filament
  pxRect(ctx,-7*s, 14*s,3*s,10*s+wag,P(fin[0],fin[1],fin[2],180));
  // Upper trailing filament
  pxRect(ctx,-7*s,-22*s,3*s,8*s-wag,P(fin[0],fin[1],fin[2],180));
  // Disc body
  pxArc(ctx,-1*s,0,9*s,13*s,body);
  pxArc(ctx,-2*s,-3*s,6*s,9*s,b2);
  pxArc(ctx,0,3*s,8*s,8*s,belly);
  // Vertical stripes (classic angelfish)
  const stripe=darker(body,70);
  pxRect(ctx,-8*s,-12*s,3*s,26*s,P(stripe[0],stripe[1],stripe[2],180));
  pxRect(ctx,-2*s,-13*s,3*s,28*s,P(stripe[0],stripe[1],stripe[2],180));
  pxRect(ctx, 4*s,-11*s,3*s,24*s,P(stripe[0],stripe[1],stripe[2],160));
  // Dorsal fin (tall sail)
  pxRect(ctx,-5*s,-17*s,10*s,5*s,fin);
  pxRect(ctx,-3*s,-15*s,7*s,4*s,lighter(fin,20));
  // Anal fin (matches dorsal)
  pxRect(ctx,-5*s,12*s,10*s,5*s,fin);
  // Pectoral fins
  pxRect(ctx,-9*s,-3*s,3*s,10*s,P(fin[0],fin[1],fin[2],190));
  // Head
