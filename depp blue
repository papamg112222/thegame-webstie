let encycSelectedId = null;
// Track how many of each fish the player has caught (accumulated)
const fishCaughtStats = {}; // id -> {count, totalSize, minDepth, maxDepth}
 
// Call this every time a fish is caught to update stats
function recordFishCatch(fish, scale, depthM){
  if(!fishCaughtStats[fish.id]){
    fishCaughtStats[fish.id]={count:0,totalSize:0,minDepth:Infinity,maxDepth:-Infinity};
  }
  const s=fishCaughtStats[fish.id];
  s.count++;
  s.totalSize+=scale;
  s.minDepth=Math.min(s.minDepth,depthM);
  s.maxDepth=Math.max(s.maxDepth,depthM);
}
 
