function selectEncycFish(id){
  encycSelectedId=id;
  // Update active row
  document.querySelectorAll('.enc-row').forEach(r=>{
    r.classList.toggle('active', parseInt(r.dataset.id)===id);
  });
 
  const fish=FISH.find(f=>f.id===id);
  if(!fish) return;
  const caught=fishCaughtStats[id];
  const detail=document.getElementById('encycDetail');
 
  const avgSize=caught ? (caught.totalSize/caught.count).toFixed(2) : '—';
  const minD=caught&&caught.minDepth!==Infinity ? caught.minDepth+'m' : '—';
  const maxD=caught&&caught.maxDepth!==-Infinity ? caught.maxDepth+'m' : '—';
  const col=RARITY_COL[fish.rarity];
  const stars='★'.repeat(fish.rarity+1)+'☆'.repeat(Math.max(0,5-fish.rarity));
 
  // Depth bar: 0–10000m range
  const depLo=fish.depth[0], depHi=fish.depth[1];
  const barLoPct=(depLo/10000*100).toFixed(1);
  const barWidPct=((depHi-depLo)/10000*100).toFixed(1);
 
  const rarityGrad={
    0:'rgba(100,100,100,0.4)',1:'rgba(20,80,20,0.4)',2:'rgba(20,40,100,0.4)',
    3:'rgba(80,0,80,0.4)',4:'rgba(80,50,0,0.4)',5:'rgba(100,0,20,0.4)'
  }[fish.rarity];
 
  detail.innerHTML=`
    <div class="enc-detail-header">
      <canvas id="enc-big-preview" width="110" height="80" style="image-rendering:pixelated;background:rgba(0,10,30,0.7);border:1px solid ${col}33;border-radius:3px;flex-shrink:0;"></canvas>
      <div class="enc-detail-texts">
        <span class="enc-detail-name" style="color:${col};text-shadow:0 0 12px ${col}66">${fish.name}</span>
        <span class="enc-detail-rarity" style="color:${col}">${stars} ${RARITY_NAME[fish.rarity].toUpperCase()}</span>
        <div style="margin-top:8px;font-size:5px;color:#2a5070;line-height:2;">
          ${caught
            ? `<span style="color:#20ff88">✓ DISCOVERED</span> &nbsp;·&nbsp; Caught <span style="color:#FFD96A">${caught.count}</span> time${caught.count!==1?'s':''}`
            : `<span style="color:#3a3a5a">? NOT YET DISCOVERED</span>`}
        </div>
      </div>
    </div>
 
    <div class="enc-stat-grid">
      <div class="enc-stat" style="background:${rarityGrad};border-color:${col}33;">
        <span class="enc-stat-label">BASE VALUE</span>
        <span class="enc-stat-val" style="color:#FFD96A">${fish.value} FC</span>
      </div>
      <div class="enc-stat">
        <span class="enc-stat-label">TOTAL CAUGHT</span>
        <span class="enc-stat-val" style="color:#4adeff">${caught?caught.count:0}</span>
      </div>
      <div class="enc-stat">
        <span class="enc-stat-label">AVG SIZE</span>
        <span class="enc-stat-val" style="color:#20ffaa">${avgSize}×</span>
      </div>
      <div class="enc-stat">
        <span class="enc-stat-label">SHALLOWEST CATCH</span>
        <span class="enc-stat-val" style="color:#4af">${minD}</span>
      </div>
      <div class="enc-stat">
        <span class="enc-stat-label">DEEPEST CATCH</span>
        <span class="enc-stat-val" style="color:#88f">${maxD}</span>
      </div>
      <div class="enc-stat">
        <span class="enc-stat-label">TOTAL EARNED</span>
        <span class="enc-stat-val" style="color:#FFD96A">${caught?Math.round(fish.value*caught.count*gs.valueBoost)+' FC':'0 FC'}</span>
      </div>
    </div>
 
    <div>
      <div class="enc-depth-section">HABITAT DEPTH RANGE</div>
      <div class="enc-depth-bar">
        <div style="position:absolute;left:${barLoPct}%;width:${barWidPct}%;height:100%;background:linear-gradient(90deg,${col}88,${col});border-radius:4px;"></div>
      </div>
      <div class="enc-depth-labels">
        <span>0m</span>
        <span>${depLo}m – ${depHi}m</span>
        <span>10,000m</span>
      </div>
    </div>
 
    <div class="enc-desc-box">
      ${getEncycDesc(fish)}
    </div>
  `;
 
  // Animate the preview canvas
  const bigCanvas=document.getElementById('enc-big-preview');
  if(bigCanvas){
    const bctx=bigCanvas.getContext('2d');
    const sc=0.9+fish.rarity*0.18;
    function animBig(){
      if(!document.getElementById('enc-big-preview')) return;
      if(encycSelectedId!==id) return;
      bctx.clearRect(0,0,110,80);
      bctx.fillStyle='rgba(0,10,30,0.7)'; bctx.fillRect(0,0,110,80);
      if(fish.glow){bctx.shadowColor=fish.glow;bctx.shadowBlur=10+Math.sin(Date.now()*0.003)*5;}
      drawPixelFish(bctx,55,40,true,sc,Date.now()*0.001,fish.body,fish.fin,fish.eye||P(255,255,255),fish.shape);
      bctx.shadowBlur=0;
      requestAnimationFrame(animBig);
    }
    animBig();
  }
}
 
// Depth bar needs position:relative on its parent — fix the inline style
function selectEncycFish(id){
  encycSelectedId=id;
  document.querySelectorAll('.enc-row').forEach(r=>{
    r.classList.toggle('active', parseInt(r.dataset.id)===id);
  });
  const fish=FISH.find(f=>f.id===id);
  if(!fish) return;
  const caught=fishCaughtStats[id];
  const detail=document.getElementById('encycDetail');
  const avgSize=caught?(caught.totalSize/caught.count).toFixed(2):'—';
  const minD=caught&&caught.minDepth!==Infinity?caught.minDepth+'m':'—';
  const maxD=caught&&caught.maxDepth!==-Infinity?caught.maxDepth+'m':'—';
  const col=RARITY_COL[fish.rarity];
  const stars='★'.repeat(fish.rarity+1)+'☆'.repeat(Math.max(0,5-fish.rarity));
  const depLo=fish.depth[0], depHi=fish.depth[1];
  const barLoPct=(depLo/10000*100).toFixed(1);
  const barWidPct=Math.max(2,(depHi-depLo)/10000*100).toFixed(1);
  const rarBg={0:'rgba(60,60,60,0.35)',1:'rgba(10,60,20,0.35)',2:'rgba(10,25,80,0.35)',3:'rgba(60,0,80,0.35)',4:'rgba(80,45,0,0.35)',5:'rgba(80,0,15,0.35)'}[fish.rarity];
 
  detail.innerHTML=`
    <div class="enc-detail-header">
      <canvas id="enc-big-preview" width="110" height="80"
        style="image-rendering:pixelated;background:rgba(0,10,30,0.75);border:1px solid ${col}44;border-radius:3px;flex-shrink:0;"></canvas>
      <div class="enc-detail-texts">
        <span class="enc-detail-name" style="color:${col};text-shadow:0 0 14px ${col}88;">${fish.name}</span>
        <span class="enc-detail-rarity" style="color:${col}">${stars} &nbsp; ${RARITY_NAME[fish.rarity].toUpperCase()}</span>
        <div style="margin-top:8px;font-size:5px;line-height:2;">
          ${caught
            ?`<span style="color:#20ff88">✓ DISCOVERED</span> &nbsp;·&nbsp; Caught <span style="color:#FFD96A">${caught.count}×</span>`
            :`<span style="color:#2a3a5a">✗ NOT YET DISCOVERED</span>`}
        </div>
      </div>
    </div>
 
    <div class="enc-stat-grid">
      <div class="enc-stat" style="background:${rarBg};border-color:${col}44;">
        <span class="enc-stat-label">BASE VALUE</span>
        <span class="enc-stat-val" style="color:#FFD96A;">${fish.value} FC</span>
      </div>
      <div class="enc-stat">
        <span class="enc-stat-label">TOTAL CAUGHT</span>
        <span class="enc-stat-val" style="color:#4adeff;">${caught?caught.count:0}</span>
      </div>
      <div class="enc-stat">
        <span class="enc-stat-label">AVG SIZE</span>
        <span class="enc-stat-val" style="color:#20ffaa;">${avgSize}×</span>
      </div>
      <div class="enc-stat">
        <span class="enc-stat-label">SHALLOWEST</span>
        <span class="enc-stat-val" style="color:#4adeff;">${minD}</span>
      </div>
      <div class="enc-stat">
        <span class="enc-stat-label">DEEPEST</span>
        <span class="enc-stat-val" style="color:#aa88ff;">${maxD}</span>
      </div>
      <div class="enc-stat">
        <span class="enc-stat-label">TOTAL EARNED</span>
        <span class="enc-stat-val" style="color:#FFD96A;">${caught?Math.round(caught.totalSize>0?(fish.value*Math.pow(caught.totalSize/caught.count,1.8)*caught.count*gs.valueBoost):0)+' FC':'0 FC'}</span>
      </div>
    </div>
 
    <div>
      <div class="enc-depth-section">HABITAT DEPTH RANGE &nbsp; <span style="color:${col}">${depLo}m – ${depHi}m</span></div>
      <div class="enc-depth-bar" style="position:relative;">
        <div style="position:absolute;left:${barLoPct}%;width:${barWidPct}%;height:100%;
          background:linear-gradient(90deg,${col}66,${col});border-radius:4px;"></div>
      </div>
      <div class="enc-depth-labels"><span>Surface 0m</span><span>Mid 5,000m</span><span>Hadal 10,000m</span></div>
    </div>
 
    <div class="enc-desc-box">${getEncycDesc(fish)}</div>
  `;
 
  // Animate big preview
  const bigC=document.getElementById('enc-big-preview');
  if(bigC){
    const bctx=bigC.getContext('2d');
    const sc=0.9+fish.rarity*0.18;
    (function animBig(){
      if(!document.getElementById('enc-big-preview')||encycSelectedId!==id) return;
      bctx.clearRect(0,0,110,80);
      bctx.fillStyle='rgba(0,8,25,0.8)'; bctx.fillRect(0,0,110,80);
      if(fish.glow){bctx.shadowColor=fish.glow;bctx.shadowBlur=8+Math.sin(Date.now()*0.003)*5;}
      drawPixelFish(bctx,55,42,true,sc,Date.now()*0.001,fish.body,fish.fin,fish.eye||P(255,255,255),fish.shape);
      bctx.shadowBlur=0;
      requestAnimationFrame(animBig);
    })();
  }
}
 
function getEncycDesc(fish){
  // Auto-generate flavour text from fish properties
  const depthZone=fish.depth[0]<100?'shallow sunlit waters':
    fish.depth[0]<500?'the twilight zone':
    fish.depth[0]<1000?'the midnight zone':
    fish.depth[0]<4000?'the abyssal depths':'the crushing hadal trenches';
  const rareAdj=['a common sight','an uncommon find','a rare encounter',
    'an epic discovery','a legendary sighting','a mythical apparition'][fish.rarity];
  const sizeDesc=RARITY_SCALE[fish.rarity]>=3.5?'immense':RARITY_SCALE[fish.rarity]>=2?'substantial':'modest';
  const glowNote=fish.glow?` It radiates a faint ${fish.glow} bioluminescent glow visible in the dark.`:'';
  return `The <strong style="color:${RARITY_COL[fish.rarity]}">${fish.name}</strong> is ${rareAdj} found in ${depthZone}, typically between ${fish.depth[0]}m and ${fish.depth[1]}m. Divers who spot one consider it quite the prize.${glowNote} Each specimen fetches <strong style="color:#FFD96A">${fish.value} Flesh Coins</strong> at the market.`;
}
 
// Also animate the miniature fish in the list while encyclopedia is open
function animateEncycList(){
  if(!document.getElementById('encycOverlay').classList.contains('open')){
    requestAnimationFrame(animateEncycList); return;
  }
  const minis=document.querySelectorAll('.enc-fish-mini');
  minis.forEach((fc,idx)=>{
    const sorted=[...FISH].sort((a,b)=>b.value-a.value);
    const fish=sorted[idx];
    if(!fish) return;
    const fctx=fc.getContext('2d');
    fctx.clearRect(0,0,44,30);
    fctx.fillStyle='rgba(0,10,30,0.8)'; fctx.fillRect(0,0,44,30);
    const sc=0.55+fish.rarity*0.12;
    if(fish.glow){fctx.shadowColor=fish.glow;fctx.shadowBlur=4;}
    drawPixelFish(fctx,22,15,true,sc,Date.now()*0.001+idx*0.3,fish.body,fish.fin,fish.eye||P(255,255,255),fish.shape);
    fctx.shadowBlur=0;
  });
  requestAnimationFrame(animateEncycList);
}
function startGame(){
  const titleEl = document.getElementById('title');
  if(titleEl) titleEl.style.display='none';
  gs.started=true;
  try{ drawShopBg(); } catch(e){}
  try{ drawSellBg(); } catch(e){}
  try{ initAdminInput(); } catch(e){}
  lastTs=performance.now();
  requestAnimationFrame(loop);
  requestAnimationFrame(animateSellPreviews);
  requestAnimationFrame(animateEncycList);
  showNotif('WALK RIGHT TO THE EDGE TO DIVE!','#4adeff');
}
window.startGame=startGame;
window.openShop=openShop;
window.openSell=openSell;
window.closeShop=closeShop;
window.closeSell=closeSell;
window.openEncyc=openEncyc;
window.closeEncyc=closeEncyc;
window.switchTab=switchTab;
window.buyUpgrade=buyUpgrade;
window.sellAll=sellAll;
</script>
