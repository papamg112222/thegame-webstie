function update(dt){
  const now=Date.now();
 
  // ── MOVEMENT ──
  const spd=gs.swimSpeed*gs.swimBoost;
  let dx=0,dy=0;
  if(keys['ArrowLeft']||keys['a']||keys['A']){dx=-1;diver.facingR=false;}
  if(keys['ArrowRight']||keys['d']||keys['D']){dx=1;diver.facingR=true;}
  if(keys['ArrowUp']||keys['w']||keys['W']){dy=-1;}
  if(keys['ArrowDown']||keys['s']||keys['S']){dy=1;}
 
  diver._moving = (dx!==0||dy!==0);
  diver._dy = dy;
 
  // Advance animation timer
  diverAnimT += dt;
 
  const swimming=diver.y>SURF_Y+2;
 
  if(!swimming){
    // On dock — horizontal movement
    diver.x+=dx*spd*1.4;
    diver.y=SURF_Y-2; // snap to dock surface
    diver.vx=0; diver.vy=0;
 
    // Press S or DOWN anywhere to dive in
    if(dy>0){
      diver.y=SURF_Y+8;
    }
  } else {
    // Underwater
    diver.x+=dx*spd;
    diver.y+=dy*(dy>0?gs.sinkSpeed:spd);
    // Buoyancy
    if(dy===0) diver.y-=0.25;
    // Surface
    if(diver.y<=SURF_Y){
      diver.y=SURF_Y-2;
      gs.curOxy=gs.maxOxy; // refill on surface
    }
    diver.underwater=true;
  }
  diver.underwater=diver.y>SURF_Y;
 
  // Clamp
  diver.x=Math.max(10,Math.min(DIVE_EDGE_X+20,diver.x));
 
  // Depth limit
  const dm=worldDepthM();
  if(dm>gs.maxDepth){ diver.y-=0.5; }
 
  // ── CAMERA ──
  const targetCam=Math.max(0,(diver.y-H*0.5));
  camY+=(targetCam-camY)*0.1;
 
  // ── OXYGEN ──
  if(diver.underwater){
    oxyTimer+=dt;
    if(oxyTimer>=1){oxyTimer=0; gs.curOxy=Math.max(0,gs.curOxy-1);}
    if(gs.curOxy<=0){
      diver.y=SURF_Y-2; gs.curOxy=gs.maxOxy;
      showNotif('⚠ OUT OF OXYGEN — SURFACED!','#f44');
    }
  } else {
    gs.curOxy=Math.min(gs.maxOxy,gs.curOxy+dt*4);
  }
 
  // ── FISH SPAWN ──
  if(diver.underwater&&Math.random()<0.025) spawnFish();
 
  // ── FISH UPDATE & CATCH ──
  for(let i=liveFish.length-1;i>=0;i--){
    const lf=liveFish[i];
    lf.t+=dt;
    lf.x+=lf.vx;
    lf.y+=lf.vy;
    lf.y+=Math.sin(lf.t*(lf.fish.rarity*0.3+0.5)+lf.phase)*0.4;
 
    // Compare in WORLD coords: diver.x vs lf.x, diver.y vs lf.y
    const fdx=diver.x - lf.x;
    const fdy=diver.y - lf.y;
    const fd=Math.sqrt(fdx*fdx+fdy*fdy);
 
    // Flee diver
    const fleeR=60/(gs.luck>50?2:1);
    if(fd<fleeR&&!lf.caught){
      lf.vx-=fdx*0.005;
      lf.vy-=fdy*0.005;
    }
    // Clamp speed
    const spd2=Math.sqrt(lf.vx*lf.vx+lf.vy*lf.vy);
    const ms=2+lf.fish.rarity*0.2;
    if(spd2>ms){lf.vx=lf.vx/spd2*ms;lf.vy=lf.vy/spd2*ms;}
 
    // Off screen remove
    if(lf.x<-150||lf.x>W+150){liveFish.splice(i,1);continue;}
 
    // Catch check — radius scales with fish size so big fish are easier to catch
    const effectiveCatchR = gs.catchRadius * Math.max(1, (lf.scale||1) * 0.7);
    if(diver.underwater&&!lf.caught&&fd<effectiveCatchR&&gs.netCount<gs.maxNet){
      catchFish(lf,i);
    }
  }
 
  // ── BUBBLES ──
  for(let i=bubbles.length-1;i>=0;i--){
    const b=bubbles[i];
    b.x+=b.vx+Math.sin(b.y*0.05)*0.3;
    b.y+=b.vy;
    b.life-=dt*0.5;
    if(b.life<=0||b.y<SURF_Y-20){bubbles.splice(i,1);}
  }
 
  // ── PARTICLES ──
  for(let i=particles.length-1;i>=0;i--){
    const p=particles[i];
    p.x+=p.vx; p.y+=p.vy; p.vy+=0.05;
    p.life-=dt*1.2;
    if(p.life<=0)particles.splice(i,1);
  }
 
  // ── FLOAT MSGS ──
  for(let i=floatMsgs.length-1;i>=0;i--){
    floatMsgs[i].y-=dt*30;
    floatMsgs[i].life-=dt;
    if(floatMsgs[i].life<=0)floatMsgs.splice(i,1);
  }
 
  // ── HUD ──
  document.getElementById('h-coins').textContent=gs.coins;
  document.getElementById('oxy-bar').style.width=(gs.curOxy/gs.maxOxy*100)+'%';
  document.getElementById('h-oxy').textContent=Math.ceil(gs.curOxy)+'s';
  document.getElementById('net-bar').style.width=(gs.netCount/gs.maxNet*100)+'%';
  document.getElementById('h-net').textContent=gs.netCount+'/'+gs.maxNet;
  document.getElementById('h-depth').textContent=dm+'m';
 
  const zones=[
    [0,'SURFACE','#6af'],[100,'SUNLIT','#4af'],[200,'TWILIGHT','#48b'],
    [500,'MIDNIGHT','#416'],[1000,'ABYSS','#314'],[4000,'HADAL','#612']
  ];
  let zn=zones[0];
  for(const z of zones){if(dm>=z[0])zn=z;}
  const zh=document.getElementById('h-zone');
  zh.textContent=zn[1]; zh.style.color=zn[2];
 
  // Notif fade
  if(notifTimer>0){notifTimer-=dt;if(notifTimer<=0)document.getElementById('notif').style.opacity=0;}
 
  // E key – interact with shops
  if(keys['e']||keys['E']){
    if(!diver.underwater){
      const dsx=diver.x;
      const anyOpen=document.getElementById('shopOL').classList.contains('open')||
                    document.getElementById('sellOL').classList.contains('open')||
                    document.getElementById('encycOverlay').classList.contains('open');
      if(dsx>20&&dsx<280&&!anyOpen) openShop();
      if(dsx>280&&dsx<560&&!anyOpen) openSell();
      if(dsx>560&&dsx<800&&!anyOpen) openEncyc();
    }
    keys['e']=false; keys['E']=false;
  }
}
 
function catchFish(lf, idx){
  lf.caught=true;
  const sc = lf.scale || 1;
  // Store each fish individually with its actual scale (size matters for value!)
  gs.catch.push({fish: lf.fish, scale: sc});
  gs.netCount++;
  // Record for encyclopedia stats
  recordFishCatch(lf.fish, sc, worldDepthM());
  // Size multiplier: bigger fish = exponentially more valuable
  // scale 1.0 = 1× value, scale 2.0 = ~3.5×, scale 4.0 = ~20×, scale 6.0 = ~60×
  const sizeMult = Math.pow(sc, 1.8);
  const sizeVal = Math.round(lf.fish.value * sizeMult * gs.valueBoost);
  const screenFX = lf.x;
  const screenFY = screenY(lf.y);
  addParticles(screenFX, screenFY, RARITY_COL[lf.fish.rarity], 6+lf.fish.rarity*4);
  // Show the actual value in the float message
  const sizeTag = sc >= 4 ? ' [GIANT!]' : sc >= 2.5 ? ' [BIG]' : sc >= 1.5 ? ' [LARGE]' : '';
  addFloatMsg(screenFX, screenFY-14,
    lf.fish.rarity>=3
      ? lf.fish.name+' ['+RARITY_NAME[lf.fish.rarity]+']'+sizeTag+' +'+sizeVal+'FC'
      : '+'+lf.fish.name+sizeTag+' +'+sizeVal+'FC',
    RARITY_COL[lf.fish.rarity]);
  liveFish.splice(idx,1);
  if(gs.netCount>=gs.maxNet) showNotif('NET FULL! Return to dock!','#fa0');
}
 
