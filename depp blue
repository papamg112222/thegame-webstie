<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>DEEP BLUE — Ocean Diver</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap');
*{margin:0;padding:0;box-sizing:border-box;}
body{background:#0a0a0f;display:flex;flex-direction:column;align-items:center;justify-content:center;height:100vh;overflow:hidden;font-family:'Press Start 2P',monospace;}
#wrap{position:relative;width:900px;height:620px;overflow:hidden;image-rendering:pixelated;border:3px solid #2a4a6a;box-shadow:0 0 40px #0af3,0 0 80px #0055aa44;}
canvas{display:block;image-rendering:pixelated;}
 
/* ── OVERLAYS ── */
.overlay{display:none;position:absolute;inset:0;z-index:100;align-items:center;justify-content:center;}
.overlay.open{display:flex;}
 
/* ── UPGRADE SHOP (wood/barnacle) ── */
#shopBox{
  width:820px;height:570px;
  position:relative;overflow:hidden;
  image-rendering:pixelated;
  border:4px solid #8B5E2A;
  box-shadow:0 0 0 3px #3d1f00, 0 0 30px #0008;
}
#shopBox canvas{position:absolute;inset:0;}
#shopBoxUI{position:absolute;inset:0;display:flex;flex-direction:column;}
.shop-title-bar{
  height:44px;display:flex;align-items:center;justify-content:space-between;
  padding:0 16px;background:rgba(20,8,0,0.85);border-bottom:3px solid #8B5E2A;
}
.shop-title-bar span{color:#FFD96A;font-size:9px;text-shadow:1px 1px 0 #000;}
.s-close{background:#5a1010;border:2px solid #a03030;color:#ff8080;font-family:'Press Start 2P',monospace;font-size:7px;padding:5px 10px;cursor:pointer;}
.s-close:hover{background:#7a1818;}
.shop-tabs{display:flex;background:rgba(0,0,0,0.6);border-bottom:2px solid #5a3a10;}
.shop-tab{flex:1;padding:8px 4px;font-family:'Press Start 2P',monospace;font-size:6px;color:#8B6020;cursor:pointer;border:none;background:transparent;border-right:1px solid #3a1f00;}
.shop-tab.active{background:rgba(139,94,42,0.3);color:#FFD96A;border-bottom:3px solid #FFD96A;}
.shop-tab:hover:not(.active){background:rgba(139,94,42,0.15);color:#c8a040;}
.shop-scroll{flex:1;overflow-y:auto;padding:12px;display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;}
.shop-scroll::-webkit-scrollbar{width:5px;}
.shop-scroll::-webkit-scrollbar-track{background:#1a0800;}
.shop-scroll::-webkit-scrollbar-thumb{background:#8B5E2A;}
.s-item{
  background:rgba(0,0,0,0.5);border:2px solid #5a3a10;border-radius:2px;
  padding:8px;display:flex;flex-direction:column;gap:5px;align-items:center;
}
.s-item:hover{border-color:#8B5E2A;}
.s-item.maxed{opacity:0.5;}
.s-icon{width:48px;height:48px;image-rendering:pixelated;}
.s-name{font-size:6px;color:#FFD96A;text-align:center;}
.s-desc{font-size:5px;color:#907040;text-align:center;line-height:1.6;}
.s-pips{display:flex;gap:2px;justify-content:center;}
.s-pip{width:10px;height:4px;background:#1a0800;border:1px solid #5a3a10;}
.s-pip.on{background:#FFD96A;border-color:#FFD96A;}
.s-buy{background:#4a2800;border:2px solid #8B5E2A;color:#FFD96A;font-family:'Press Start 2P',monospace;font-size:6px;padding:4px 8px;cursor:pointer;width:100%;}
.s-buy:hover:not(:disabled){background:#6a3808;}
.s-buy:disabled{opacity:0.4;cursor:not-allowed;}
.shop-coins-bar{padding:6px 12px;background:rgba(0,0,0,0.7);border-top:2px solid #5a3a10;font-size:7px;color:#FFD96A;}
 
/* ── SELL SHOP (ocean/blue) ── */
#sellBox{
  width:760px;height:540px;
  position:relative;overflow:hidden;
  border:4px solid #1a5a8a;
  box-shadow:0 0 0 3px #001a40, 0 0 30px #00f8;
}
#sellBox canvas{position:absolute;inset:0;}
#sellBoxUI{position:absolute;inset:0;display:flex;flex-direction:column;}
.sell-title-bar{
  height:44px;display:flex;align-items:center;justify-content:space-between;
  padding:0 16px;background:rgba(0,10,30,0.9);border-bottom:3px solid #1a5a8a;
}
.sell-title-bar span{color:#4adeff;font-size:9px;text-shadow:0 0 8px #0af;}
.sell-scroll{flex:1;overflow-y:auto;padding:12px;}
.sell-scroll::-webkit-scrollbar{width:5px;}
.sell-scroll::-webkit-scrollbar-track{background:#000a1a;}
.sell-scroll::-webkit-scrollbar-thumb{background:#1a5a8a;}
.sell-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:8px;margin-bottom:12px;}
.sell-item{background:rgba(0,30,80,0.6);border:2px solid #1a4a7a;border-radius:2px;padding:8px;text-align:center;}
.sell-item-canvas{image-rendering:pixelated;display:block;margin:0 auto 4px;}
.sell-item-name{font-size:5px;color:#4adeff;margin-bottom:2px;}
.sell-item-val{font-size:6px;color:#FFD96A;}
.sell-item-qty{font-size:5px;color:#6080a0;}
.sell-all-btn{
  display:block;width:100%;padding:12px;
  background:rgba(0,40,100,0.8);border:3px solid #1a5a8a;
  color:#4adeff;font-family:'Press Start 2P',monospace;font-size:8px;cursor:pointer;
  text-shadow:0 0 8px #0af;transition:all .15s;
}
.sell-all-btn:hover{background:rgba(0,60,140,0.8);box-shadow:0 0 20px #0af4;}
.sell-total{font-size:7px;color:#FFD96A;text-align:center;padding:6px;background:rgba(0,0,0,0.5);}
.sell-coins-bar{padding:6px 12px;background:rgba(0,0,0,0.7);border-top:2px solid #1a5a8a;font-size:7px;color:#4adeff;}
 
/* ── HUD ── */
#hud{position:absolute;top:6px;left:6px;right:56px;display:flex;gap:6px;z-index:20;pointer-events:none;}
.hud-c{background:rgba(0,0,0,0.75);border:2px solid #2a4a2a;padding:4px 8px;display:flex;align-items:center;gap:5px;}
.hud-label{font-size:5px;color:#8ab;white-space:nowrap;}
.hud-bar-wrap{width:70px;height:7px;background:#111;border:1px solid #333;}
.hud-bar{height:100%;transition:width .3s;}
#oxy-bar{background:linear-gradient(90deg,#0af,#0ff);}
#net-bar{background:linear-gradient(90deg,#4a8,#8f8);}
.hud-val{font-size:6px;color:#eee;white-space:nowrap;}
 
/* ── NOTIF ── */
#notif{
  position:absolute;bottom:50px;left:50%;transform:translateX(-50%);
  background:rgba(0,0,0,0.9);border:2px solid #8B5E2A;
  padding:7px 14px;font-size:6px;color:#FFD96A;z-index:80;
  pointer-events:none;white-space:nowrap;transition:opacity .4s;
}
 
/* ── ADMIN BADGE ── */
#adminBadge{
  display:none;position:absolute;top:38px;right:8px;z-index:300;
  width:270px;background:linear-gradient(135deg,#1a0a00,#2d1200);
  border:2px solid #FFD96A;border-radius:4px;padding:10px 14px;
  box-shadow:0 0 24px rgba(255,215,0,0.4),inset 0 0 10px rgba(0,0,0,0.5);
  pointer-events:none;
  animation:slideInRight 0.4s ease-out;
}
@keyframes slideInRight{from{transform:translateX(120%);opacity:0;}to{transform:translateX(0);opacity:1;}}
#adminBadge .ab-icon{font-size:22px;float:left;margin-right:10px;line-height:1;}
#adminBadge .ab-title{font-size:9px;color:#FFD96A;text-shadow:0 0 8px rgba(255,215,0,0.6);display:block;margin-bottom:3px;}
#adminBadge .ab-sub{font-size:7px;color:#c8a45a;display:block;}
#adminTag{
  display:none;position:absolute;top:32px;right:8px;z-index:280;
  background:rgba(255,215,0,0.12);border:1px solid #FFD96A;border-radius:2px;
  padding:3px 8px;font-size:7px;color:#FFD96A;pointer-events:none;
  text-shadow:0 0 6px rgba(255,215,0,0.5);
}
/* ── ADMIN CONSOLE ── */
#adminConsole{
  display:none;position:absolute;left:10px;right:10px;bottom:8px;z-index:400;
  background:rgba(4,2,0,0.97);border:2px solid #FFD96A;border-radius:4px;
  box-shadow:0 0 30px rgba(255,215,0,0.3),inset 0 0 20px rgba(0,0,0,0.6);
  font-family:'Press Start 2P',monospace;overflow:hidden;
}
#adminConsole.open{display:block;}
#ac-header{
  background:linear-gradient(90deg,#1a0800,#2d1200,#1a0800);
  border-bottom:2px solid #FFD96A;padding:8px 14px;
  display:flex;align-items:center;justify-content:space-between;
}
#ac-header span{font-size:9px;color:#FFD96A;text-shadow:0 0 8px rgba(255,215,0,0.5);}
#ac-header small{font-size:7px;color:#907040;}
#ac-inputrow{
  padding:8px 12px;display:flex;align-items:center;gap:8px;
  border-bottom:1px solid rgba(255,215,0,0.2);background:rgba(0,0,0,0.4);
}
#ac-prompt{font-size:11px;color:#FFD96A;}
#ac-input{
  flex:1;background:transparent;border:none;outline:none;
  font-family:'Press Start 2P',monospace;font-size:11px;
  color:#FFD96A;caret-color:#FFD96A;
}
#ac-input::placeholder{color:#4a3000;}
#ac-body{display:flex;gap:0;height:200px;}
#ac-cmds{
  flex:1;padding:8px 12px;overflow-y:auto;border-right:1px solid rgba(255,215,0,0.15);
}
#ac-cmds::-webkit-scrollbar{width:4px;}
#ac-cmds::-webkit-scrollbar-thumb{background:#FFD96A44;}
#ac-fish-panel{
  width:320px;padding:8px 12px;overflow-y:auto;
  background:rgba(0,20,50,0.5);
}
#ac-fish-panel::-webkit-scrollbar{width:4px;}
#ac-fish-panel::-webkit-scrollbar-thumb{background:#4adeff44;}
.ac-section-label{font-size:7px;color:#907040;margin-bottom:6px;display:block;}
.ac-cmd-row{
  padding:5px 6px;margin-bottom:4px;border-radius:2px;cursor:pointer;
  border:1px solid transparent;transition:all 0.1s;
}
.ac-cmd-row:hover,.ac-cmd-row.highlight{background:rgba(255,215,0,0.08);border-color:rgba(255,215,0,0.3);}
.ac-cmd-text{font-size:8px;color:#FFD96A;display:block;margin-bottom:2px;}
.ac-cmd-desc{font-size:6px;color:#907040;display:block;}
.ac-fish-row{
  padding:4px 6px;margin-bottom:3px;border-radius:2px;cursor:pointer;
  border:1px solid rgba(255,255,255,0.05);transition:all 0.1s;
}
.ac-fish-row:hover{background:rgba(68,170,255,0.1);border-color:rgba(68,170,255,0.3);}
.ac-fish-name{font-size:8px;display:block;margin-bottom:1px;}
.ac-fish-meta{font-size:6px;color:#4a6080;display:block;}
#ac-result{
  padding:6px 12px;font-size:8px;border-top:1px solid rgba(255,215,0,0.2);
  min-height:22px;background:rgba(0,0,0,0.3);
}
 
/* ── FISH ENCYCLOPEDIA ── */
#encycOverlay{
  display:none;position:absolute;inset:0;z-index:150;
  align-items:center;justify-content:center;background:rgba(0,5,20,0.88);
}
#encycOverlay.open{display:flex;}
#encycBox{
  width:820px;height:570px;position:relative;overflow:hidden;
  border:4px solid #1a5a8a;border-radius:3px;
  box-shadow:0 0 0 3px #001a40,0 0 40px rgba(0,100,200,0.4);
  background:linear-gradient(160deg,#000a1a,#001a38,#000a1a);
  display:flex;flex-direction:column;
}
#encycHeader{
  height:46px;flex-shrink:0;display:flex;align-items:center;justify-content:space-between;
  padding:0 18px;background:rgba(0,10,30,0.95);border-bottom:3px solid #1a5a8a;
}
#encycHeader h2{font-size:10px;color:#4adeff;text-shadow:0 0 10px #0af;letter-spacing:2px;margin:0;}
#encycBody{flex:1;display:flex;overflow:hidden;min-height:0;}
#encycList{
  width:290px;flex-shrink:0;overflow-y:auto;border-right:2px solid rgba(26,90,138,0.4);padding:6px 0;
}
#encycList::-webkit-scrollbar{width:5px;}
#encycList::-webkit-scrollbar-thumb{background:#1a5a8a;border-radius:3px;}
.enc-row{
  display:flex;align-items:center;gap:8px;padding:6px 10px;cursor:pointer;
  border-left:3px solid transparent;transition:all 0.1s;border-bottom:1px solid rgba(255,255,255,0.03);
}
.enc-row:hover{background:rgba(68,170,255,0.08);border-left-color:#4adeff;}
.enc-row.active{background:rgba(68,170,255,0.15);border-left-color:#FFD96A;}
.enc-rank{font-size:6px;color:#2a4a6a;width:18px;text-align:right;flex-shrink:0;}
.enc-fish-mini{flex-shrink:0;image-rendering:pixelated;background:rgba(0,10,30,0.6);border-radius:2px;}
.enc-info{flex:1;min-width:0;}
.enc-name{font-size:6px;display:block;margin-bottom:2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.enc-sub{font-size:5px;color:#2a4a6a;display:block;}
#encycDetail{
  flex:1;padding:18px 20px;overflow-y:auto;display:flex;flex-direction:column;gap:12px;min-width:0;
}
#encycDetail::-webkit-scrollbar{width:5px;}
#encycDetail::-webkit-scrollbar-thumb{background:#1a5a8a;}
.enc-detail-header{display:flex;align-items:center;gap:16px;}
.enc-detail-texts{flex:1;}
.enc-detail-name{font-size:13px;display:block;margin-bottom:5px;}
.enc-detail-rarity{font-size:7px;display:block;letter-spacing:1px;}
.enc-stat-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;}
.enc-stat{
  background:rgba(0,25,60,0.5);border:1px solid rgba(26,90,138,0.45);
  border-radius:3px;padding:8px 10px;
}
.enc-stat-label{font-size:5px;color:#2a5070;display:block;margin-bottom:4px;letter-spacing:1px;}
.enc-stat-val{font-size:11px;display:block;font-weight:bold;}
.enc-depth-section{font-size:5px;color:#2a5070;letter-spacing:1px;}
.enc-depth-bar{height:7px;background:rgba(0,15,40,0.6);border-radius:4px;overflow:hidden;margin-top:5px;position:relative;}
.enc-depth-fill{height:100%;border-radius:4px;}
.enc-depth-labels{display:flex;justify-content:space-between;font-size:5px;color:#2a4060;margin-top:2px;}
.enc-empty{
  flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;
  color:#1a3a5a;font-size:7px;text-align:center;gap:12px;
}
#encycFooter{
  height:32px;flex-shrink:0;display:flex;align-items:center;justify-content:space-between;
  padding:0 18px;background:rgba(0,10,30,0.95);border-top:2px solid rgba(26,90,138,0.3);
  font-size:5px;color:#2a5070;
}
 
#title{
  position:absolute;inset:0;z-index:200;
  background:linear-gradient(180deg,#000d20,#001a40 50%,#003366);
  display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px;
}
.t-title{font-size:32px;color:#0af;text-shadow:0 0 20px #0af,0 0 40px #06f;letter-spacing:4px;animation:glow 2s ease-in-out infinite alternate;}
@keyframes glow{from{text-shadow:0 0 20px #0af,0 0 40px #06f;}to{text-shadow:0 0 40px #4ff,0 0 80px #0af;}}
.t-sub{font-size:8px;color:#4a8;letter-spacing:3px;}
.t-desc{font-size:6px;color:#468;line-height:2.2;text-align:center;max-width:500px;}
.t-start{
  padding:12px 36px;background:#001a40;border:2px solid #0af;
  color:#0af;font-family:'Press Start 2P',monospace;font-size:10px;cursor:pointer;
  animation:blink 1s step-end infinite;
}
@keyframes blink{50%{border-color:transparent;color:transparent;}}
.t-start:hover{animation:none;background:#002a60;box-shadow:0 0 20px #0af4;}
.t-ctrl{font-size:5px;color:#345;line-height:2.5;text-align:center;}
</style>
</head>
<body>
<div id="wrap">
  <canvas id="gc" width="900" height="620"></canvas>
 
  <!-- HUD -->
  <div id="hud">
    <div class="hud-c"><span class="hud-label">FC</span><span class="hud-val" id="h-coins">50</span></div>
    <div class="hud-c"><span class="hud-label">O2</span><div class="hud-bar-wrap"><div class="hud-bar" id="oxy-bar" style="width:100%"></div></div><span class="hud-val" id="h-oxy">60s</span></div>
    <div class="hud-c"><span class="hud-label">NET</span><div class="hud-bar-wrap"><div class="hud-bar" id="net-bar" style="width:0%"></div></div><span class="hud-val" id="h-net">0/5</span></div>
    <div class="hud-c"><span class="hud-label">DEPTH</span><span class="hud-val" id="h-depth">0m</span></div>
    <div class="hud-c"><span class="hud-label">ZONE</span><span class="hud-val" id="h-zone" style="color:#6af">SURFACE</span></div>
  </div>
 
  <!-- Notif -->
  <div id="notif" style="opacity:0">—</div>
 
  <!-- UPGRADE SHOP -->
  <div class="overlay" id="shopOL">
    <div id="shopBox">
      <canvas id="shopBgC" width="820" height="570"></canvas>
      <div id="shopBoxUI">
        <div class="shop-title-bar">
          <span>⚓ BARNACLE BAZAAR — UPGRADES</span>
          <div style="display:flex;gap:8px;align-items:center;">
            <span style="font-size:6px;color:#FFD96A;">FLESH COINS: <span id="shop-coins">0</span></span>
            <button class="s-close" onclick="closeShop()">✕ CLOSE</button>
          </div>
        </div>
        <div class="shop-tabs">
          <button class="shop-tab active" onclick="switchTab('speed',this)">SPEED &amp; GEAR</button>
          <button class="shop-tab" onclick="switchTab('net',this)">NET SIZE</button>
          <button class="shop-tab" onclick="switchTab('oxygen',this)">OXYGEN</button>
          <button class="shop-tab" onclick="switchTab('luck',this)">LUCK</button>
        </div>
        <div class="shop-scroll" id="shop-content"></div>
        <div class="shop-coins-bar">FLESH COINS: <span id="shop-coins2">0</span> FC &nbsp;|&nbsp; <span id="shop-hint" style="color:#907040;font-size:6px;"></span></div>
      </div>
    </div>
  </div>
 
  <!-- SELL SHOP -->
  <div class="overlay" id="sellOL">
    <div id="sellBox">
      <canvas id="sellBgC" width="760" height="540"></canvas>
      <div id="sellBoxUI">
        <div class="sell-title-bar">
          <span>🐟 FISH MARKET — SELL YOUR CATCH</span>
          <div style="display:flex;gap:8px;align-items:center;">
            <span style="font-size:6px;color:#4adeff;">FC: <span id="sell-coins">0</span></span>
            <button class="s-close" style="border-color:#1a5a8a;color:#4adeff;" onclick="closeSell()">✕ CLOSE</button>
          </div>
        </div>
        <div class="sell-scroll">
          <div class="sell-grid" id="sell-grid"></div>
          <div class="sell-total" id="sell-total"></div>
          <button class="sell-all-btn" onclick="sellAll()">▶ SELL ALL FOR FLESH COINS ◀</button>
        </div>
        <div class="sell-coins-bar">FLESH COINS: <span id="sell-coins2">0</span> FC</div>
      </div>
    </div>
  </div>
 
  <!-- FISH ENCYCLOPEDIA -->
  <div class="overlay" id="encycOverlay">
    <div id="encycBox">
      <div id="encycHeader">
        <h2>📖 FISH ENCYCLOPEDIA</h2>
        <div style="display:flex;gap:12px;align-items:center;">
          <span id="encycTotalLabel" style="font-size:6px;color:#4a6080;"></span>
          <button class="s-close" style="border-color:#1a5a8a;color:#4adeff;" onclick="closeEncyc()">✕ CLOSE</button>
        </div>
      </div>
      <div id="encycBody">
        <div id="encycList"></div>
        <div id="encycDetail">
          <div class="enc-empty">
            <div style="font-size:24px;">🐟</div>
            <div>Click any fish to see details</div>
          </div>
        </div>
      </div>
      <div id="encycFooter">
        <span>ALL FISH SORTED BY VALUE · CLICK TO VIEW DETAILS</span>
        <span id="encycPageInfo"></span>
      </div>
    </div>
  </div>
 
  <!-- ADMIN BADGE -->
  <div id="adminBadge">
    <div class="ab-icon">⚙️</div>
    <span class="ab-title">ADMIN MODE UNLOCKED</span>
    <span class="ab-sub">Press  /  for admin commands</span>
  </div>
  <div id="adminTag">⚙ ADMIN</div>
 
  <!-- ADMIN CONSOLE -->
  <div id="adminConsole">
    <div id="ac-header">
      <span>⚙ ADMIN CONSOLE</span>
      <small>ESC to close &nbsp;|&nbsp; ENTER to run &nbsp;|&nbsp; TAB to complete</small>
    </div>
    <div id="ac-inputrow">
      <span id="ac-prompt">&gt;</span>
      <input id="ac-input" type="text" placeholder="type a command..." autocomplete="off" spellcheck="false">
    </div>
    <div id="ac-body">
      <div id="ac-cmds">
        <span class="ac-section-label">COMMANDS</span>
        <div id="ac-cmd-list"></div>
      </div>
      <div id="ac-fish-panel">
        <span class="ac-section-label">FISH LIST <span id="ac-fish-count" style="color:#4adeff;background:rgba(0,100,200,0.3);border:1px solid #4adeff;border-radius:2px;padding:1px 5px;margin-left:4px;">70</span></span>
        <div id="ac-fish-list"></div>
      </div>
    </div>
    <div id="ac-result"></div>
  </div>
 
  <!-- TITLE -->
  <div id="title">
    <div class="t-title">DEEP BLUE</div>
    <div class="t-sub">OCEAN DIVER</div>
    <div class="t-desc">
      Plunge into the abyss. The ocean holds countless treasures —<br>
      mythical beasts, glowing leviathans, creatures unknown.<br>
      Spend your Flesh Coins wisely and descend further than any soul before.
    </div>
    <div class="t-ctrl">
      WASD / ARROW KEYS — Move &nbsp;|&nbsp; Walk to dock EDGE to dive<br>
      E — Open shop when near sign &nbsp;|&nbsp; ESC — Close menu<br>
      Walk back to dock surface to resurface
    </div>
    <button class="t-start" onclick="startGame()">▶ PRESS TO DIVE ◀</button>
  </div>
