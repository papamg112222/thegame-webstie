    drawPixelFish(fctx,22,15,true,previewSc,Date.now()*0.001,fish.body,fish.fin,fish.eye||P(255,255,255),fish.shape);
    fctx.shadowBlur=0;
 
    row.innerHTML=`
      <span class="enc-rank">#${idx+1}</span>
    `;
    row.appendChild(fc);
    row.innerHTML+=`
      <div class="enc-info">
        <span class="enc-name" style="color:${RARITY_COL[fish.rarity]}">${fish.name}</span>
        <span class="enc-sub">${RARITY_NAME[fish.rarity]} · ${fish.value}FC${caught?' · ×'+caught.count:' · unseen'}</span>
      </div>
    `;
    row.onclick=()=>selectEncycFish(fish.id);
    list.appendChild(row);
  });
 
  document.getElementById('encycPageInfo').textContent=
