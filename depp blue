// pixels per metre in ocean — 2px = 1m, so screen height ~300px = ~150m
const PX_PER_M = 2.0;
 
function worldDepthM(){
  // How many metres below surface the diver is
  const worldY = diver.y; // diver.y is in world coords (0=dock top, SURF_Y=ocean surface)
  const belowSurf = worldY - SURF_Y;
  if(belowSurf <= 0) return 0;
  return Math.round(belowSurf / PX_PER_M);
}
 
function screenY(worldY){ return worldY - camY; }
function worldY(screenY){ return screenY + camY; }
 
// ═══════════════════════════════════════════════════════
//  PIXEL ART DRAW ROUTINES
// ═══════════════════════════════════════════════════════
 
function drawSky(){
  // Sky gradient
  const g=ctx.createLinearGradient(0,0,0,SURF_Y-camY);
  g.addColorStop(0,'#87ceeb'); g.addColorStop(1,'#b0d8f0');
  ctx.fillStyle=g;
  ctx.fillRect(0,0,W,Math.max(0,SURF_Y-camY));
}
 
function drawOcean(){
  const depth=worldDepthM();
  const t=Math.min(1,depth/4000);
  const r=Math.round(0*(1-t));
  const g=Math.round(80*(1-t)+2*t);
  const b=Math.round(140*(1-t)+15*t);
  const r2=Math.round(0);
  const g2=Math.round(40*(1-t)+1*t);
  const b2=Math.round(100*(1-t)+8*t);
  const sy=Math.max(0,SURF_Y-camY);
  const og=ctx.createLinearGradient(0,sy,0,H);
  og.addColorStop(0,`rgb(${r},${g},${b})`);
  og.addColorStop(1,`rgb(${r2},${g2},${b2})`);
  ctx.fillStyle=og;
  ctx.fillRect(0,sy,W,H-sy);
 
  // Caustic rays (shallow)
  if(depth<800){
    const alpha=Math.max(0,0.07*(1-depth/800));
    ctx.save();
    const now=Date.now()*0.0005;
    for(let i=0;i<8;i++){
      const rx=(i*130+now*40)%W;
      ctx.beginPath();
      ctx.moveTo(rx,sy);
      ctx.lineTo(rx-60,H);
      ctx.lineTo(rx+60,H);
      ctx.closePath();
      ctx.fillStyle=`rgba(255,255,200,${alpha})`;
      ctx.fill();
    }
    ctx.restore();
  }
 
  // Deep particles
  if(depth>100){
    const now=Date.now();
    ctx.fillStyle=`rgba(100,150,255,${Math.min(0.4,depth/3000)*0.4})`;
    for(let i=0;i<20;i++){
      const px=((i*73+now*0.001*(i%3+0.3))%W+W)%W;
      const py=sy+10+((i*97+now*0.0005*(i%4+0.5))%(H-sy-20)+H-sy-20)%(H-sy-20);
      ctx.beginPath(); ctx.arc(px,py,1,0,Math.PI*2); ctx.fill();
    }
  }
 
  // Water surface shimmer
  ctx.strokeStyle='rgba(180,240,255,0.25)'; ctx.lineWidth=1.5;
  const now=Date.now()*0.001;
  for(let r=0;r<2;r++){
    ctx.beginPath();
    for(let x=0;x<=W;x+=4){
      const y=(SURF_Y-camY)+Math.sin(x/40+now+r*2)*2;
      if(x===0)ctx.moveTo(x,y); else ctx.lineTo(x,y);
    }
    ctx.stroke();
  }
}
 
function drawDock(){
  const sy=screenY(SURF_Y);
  if(sy<-DOCK_H||sy>H+10) return;
 
  const dockTop=sy-DOCK_H;
 
  // Planks
  ctx.fillStyle='#5a3010';
  ctx.fillRect(0,dockTop,W,DOCK_H);
 
  // Plank lines
  ctx.strokeStyle='#3a1800'; ctx.lineWidth=2;
  for(let i=0;i<W;i+=32){
