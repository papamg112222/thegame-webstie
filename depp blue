function drawDepthRuler(){
  const rx=W-46, ry=50, rh=500, rw=40;
  const dm=worldDepthM();
  const maxD=Math.max(dm+500,2000);
 
  // Background
  ctx.fillStyle='rgba(0,8,20,0.75)';
  ctx.fillRect(rx,ry,rw,rh);
  ctx.strokeStyle='rgba(68,170,255,0.5)'; ctx.lineWidth=1;
  ctx.strokeRect(rx,ry,rw,rh);
 
  ctx.fillStyle='#4adeff'; ctx.font="5px 'Press Start 2P'"; ctx.textAlign='center';
  ctx.fillText(dm+'m',rx+rw/2,ry+12);
 
  const marks=[0,10,50,100,200,500,1000,2000,3000,5000,10000];
  for(const m of marks){
    if(m>maxD) break;
    const py=ry+18+(m/maxD)*(rh-22);
    if(py>ry+rh-4) continue;
    ctx.strokeStyle=dm>=m?'rgba(255,215,0,0.6)':'rgba(68,170,255,0.5)';
    ctx.lineWidth=m%1000===0?2:1;
    ctx.beginPath(); ctx.moveTo(rx+2,py); ctx.lineTo(rx+12,py); ctx.stroke();
    ctx.fillStyle=m%1000===0?'#8af':'#346';
    ctx.font="4px 'Press Start 2P'"; ctx.textAlign='left';
    ctx.fillText(m>=1000?m/1000+'km':m+'m',rx+14,py+3);
  }
  // Current marker
  const curPy=ry+18+Math.min(1,dm/maxD)*(rh-22);
  ctx.fillStyle='#FFD96A';
  ctx.beginPath();
  ctx.moveTo(rx,curPy); ctx.lineTo(rx+8,curPy-4); ctx.lineTo(rx+8,curPy+4);
  ctx.closePath(); ctx.fill();
}
 
function render(dt){
  ctx.clearRect(0,0,W,H);
 
  drawSky();
  drawOcean();
  drawDock();
 
  // ── FISH ──
  for(const lf of liveFish){
    const fy=screenY(lf.y);
    const sc=lf.scale||1;
    // Cull generously for big fish
    const cullPad=60*sc;
    if(fy<-cullPad||fy>H+cullPad) continue;
 
    const glowCol=lf.fish.glow;
    const now=Date.now()*0.001;
 
    if(glowCol && lf.fish.rarity>=2){
      ctx.save();
      // Rarity-based layered aura BEFORE drawing the fish
      const auraLayers=[
        {r:lf.fish.rarity>=5?5:3, blur:55+sc*30, alpha:0.07},
        {r:lf.fish.rarity>=4?4:2, blur:30+sc*18, alpha:0.13},
        {r:2,                      blur:14+sc*8,  alpha:0.25},
      ];
      const pulse=(Math.sin(now*2.2)+1)*0.5;
      for(const L of auraLayers){
        // Draw a soft radial glow circle
        const grad=ctx.createRadialGradient(lf.x,fy,0,lf.x,fy,(L.blur+pulse*8)*sc);
        const [gr,gg,gb]=glowCol.startsWith('#')
          ?[parseInt(glowCol.slice(1,3),16),parseInt(glowCol.slice(3,5),16),parseInt(glowCol.slice(5,7),16)]
          :[120,200,255];
        grad.addColorStop(0,`rgba(${gr},${gg},${gb},${(L.alpha+pulse*0.06)*sc*0.5+L.alpha})`);
        grad.addColorStop(0.4,`rgba(${gr},${gg},${gb},${L.alpha*0.4})`);
        grad.addColorStop(1,`rgba(${gr},${gg},${gb},0)`);
        ctx.fillStyle=grad;
        ctx.beginPath();
        ctx.arc(lf.x,fy,(L.blur+pulse*10)*sc,0,Math.PI*2);
        ctx.fill();
      }
      ctx.restore();
    }
 
    // Draw the fish itself (scaled by rarity)
    drawPixelFish(ctx,lf.x,fy,lf.vx>0,sc,lf.t,lf.fish.body,lf.fish.fin,lf.fish.eye||P(255,255,255),lf.fish.shape,glowCol);
 
    // Name label — all fish show name, rarer fish get bigger/fancier label
    const labelY=fy - 14*sc - 8;
    if(lf.fish.rarity===0){
      ctx.fillStyle='rgba(180,210,255,0.7)';
      ctx.font="4px 'Press Start 2P'"; ctx.textAlign='center';
      ctx.fillText(lf.fish.name,lf.x,labelY);
    } else if(lf.fish.rarity===1){
      ctx.fillStyle=RARITY_COL[1];
      ctx.font="5px 'Press Start 2P'"; ctx.textAlign='center';
      ctx.fillText(lf.fish.name,lf.x,labelY);
    } else {
      // Rarity 2+ — glowing label with background
      const col=RARITY_COL[lf.fish.rarity];
      const pulse=(Math.sin(now*3)+1)*0.5;
      const fontSize=5+lf.fish.rarity;
      ctx.font=`${fontSize}px 'Press Start 2P'`;
      ctx.textAlign='center';
      const tw=ctx.measureText(lf.fish.name).width;
      // Background pill
      ctx.fillStyle=`rgba(0,0,0,0.65)`;
      ctx.fillRect(lf.x-tw/2-5, labelY-fontSize-1, tw+10, fontSize+5);
      ctx.strokeStyle=col;
      ctx.lineWidth=1;
      ctx.strokeRect(lf.x-tw/2-5, labelY-fontSize-1, tw+10, fontSize+5);
      // Glowing text
      ctx.shadowColor=col; ctx.shadowBlur=6+pulse*6;
      ctx.fillStyle=col;
      ctx.fillText(lf.fish.name,lf.x,labelY);
      ctx.shadowBlur=0;
      // Rarity badge
      ctx.fillStyle=`rgba(0,0,0,0.8)`;
      ctx.fillRect(lf.x-tw/2-5, labelY+5, tw+10, 9);
      ctx.fillStyle=col;
      ctx.font="4px 'Press Start 2P'";
      ctx.fillText('★'.repeat(lf.fish.rarity)+' '+RARITY_NAME[lf.fish.rarity].toUpperCase()+' ★'.repeat(lf.fish.rarity),lf.x,labelY+12);
    }
  }
 
  // Bubbles
  ctx.save();
  for(const b of bubbles){
    const by=screenY(b.y);
    ctx.globalAlpha=b.life*0.7;
    ctx.strokeStyle='rgba(150,220,255,0.9)'; ctx.lineWidth=1;
    ctx.beginPath(); ctx.arc(b.x,by,b.r,0,Math.PI*2); ctx.stroke();
  }
  ctx.globalAlpha=1; ctx.restore();
 
  // Particles (stored in screen coords)
  for(const p of particles){
    ctx.globalAlpha=Math.max(0,p.life);
    ctx.fillStyle=p.color;
    ctx.fillRect(Math.floor(p.x-p.r/2),Math.floor(p.y-p.r/2),Math.floor(p.r),Math.floor(p.r));
  }
  ctx.globalAlpha=1;
 
  // Float messages (stored in screen coords)
  ctx.save();
  for(const fm of floatMsgs){
    ctx.globalAlpha=Math.min(1,fm.life);
    ctx.fillStyle=fm.col;
    ctx.font="6px 'Press Start 2P'";
    ctx.textAlign='center';
    ctx.fillText(fm.text,Math.floor(fm.x),Math.floor(fm.y));
  }
  ctx.restore();
 
  // Diver
  drawDiver();
 
  // Depth ruler
  drawDepthRuler();
 
  // Low oxy warning
  if(gs.curOxy<gs.maxOxy*0.25&&diver.underwater){
    const alpha=(Math.sin(Date.now()*0.005)+1)*0.12;
    ctx.fillStyle=`rgba(255,30,30,${alpha})`;
    ctx.fillRect(0,0,W,H);
    ctx.fillStyle='rgba(255,80,80,0.9)';
    ctx.font="8px 'Press Start 2P'"; ctx.textAlign='center';
    ctx.fillText('! LOW OXYGEN !',W/2,H-20);
  }
 
  // Zone indicator
  const zones2=[
    [0,'SUNLIT ZONE','#4af'],[200,'TWILIGHT ZONE','#48b'],
    [500,'MIDNIGHT ZONE','#314'],[1000,'ABYSSAL ZONE','#212'],
    [4000,'HADAL ZONE','#611']
  ];
  let z2=zones2[0];
  const dm2=worldDepthM();
  for(const z of zones2){if(dm2>=z[0])z2=z;}
  ctx.fillStyle=z2[2]; ctx.font="5px 'Press Start 2P'"; ctx.textAlign='left';
  ctx.shadowColor=z2[2]; ctx.shadowBlur=4;
  ctx.fillText(z2[1],8,H-8); ctx.shadowBlur=0;
 
  // Shop proximity indicator
  if(!diver.underwater){
    const dsx=diver.x;
    if(dsx>20&&dsx<280){
      ctx.fillStyle='rgba(255,215,0,0.9)'; ctx.font="5px 'Press Start 2P'"; ctx.textAlign='center';
      ctx.fillText('[E] OPEN SHOP',150,H-8);
    }
    if(dsx>280&&dsx<560){
      ctx.fillStyle='rgba(68,222,255,0.9)'; ctx.font="5px 'Press Start 2P'"; ctx.textAlign='center';
      ctx.fillText('[E] SELL FISH',440,H-8);
    }
    if(dsx>DIVE_EDGE_X-80){
      ctx.fillStyle='rgba(255,215,0,0.9)'; ctx.font="5px 'Press Start 2P'"; ctx.textAlign='center';
      ctx.fillText('WALK RIGHT TO DIVE',DIVE_EDGE_X-10,H-8);
    }
  }
 
  // ── BEAST ANNOUNCEMENT ──
  if(beastMsg && beastMsgTimer > 0){
    beastMsgTimer -= dt;
    const alpha = beastMsgTimer < 1 ? beastMsgTimer : Math.min(1, (6-beastMsgTimer+0.5)*3);
    const pulse = (Math.sin(Date.now()*0.006)+1)*0.5;
    const col = beastMsg.col||'#ff4400';
    const bw = 660, bh = 72, bx = (W-bw)/2, by = 14;
 
    ctx.save();
    ctx.globalAlpha = Math.max(0, alpha);
 
    // Shadow glow
    ctx.shadowColor = col; ctx.shadowBlur = 20+pulse*10;
    // Background
    ctx.fillStyle = 'rgba(0,0,0,0.88)';
    ctx.fillRect(bx, by, bw, bh);
    // Coloured border
    ctx.strokeStyle = col; ctx.lineWidth = 2;
    ctx.strokeRect(bx, by, bw, bh);
    // Inner accent line
    ctx.strokeStyle = `rgba(${parseInt(col.slice(1,3),16)||255},${parseInt(col.slice(3,5),16)||100},${parseInt(col.slice(5,7),16)||0},0.4)`;
    ctx.lineWidth = 1;
    ctx.strokeRect(bx+3, by+3, bw-6, bh-6);
    ctx.shadowBlur = 0;
 
    // Warning icon
    ctx.fillStyle = col;
    ctx.font = "18px serif";
    ctx.textAlign = 'left';
    ctx.fillText('⚠', bx+14, by+28);
 
    // Line 1 — fish name
    ctx.fillStyle = col;
    ctx.font = "10px 'Press Start 2P'";
    ctx.textAlign = 'center';
    ctx.shadowColor = col; ctx.shadowBlur = 8+pulse*6;
    ctx.fillText(beastMsg.text1, W/2, by+25);
    ctx.shadowBlur = 0;
 
    // Line 2 — depth info
    ctx.fillStyle = '#FFD96A';
    ctx.font = "7px 'Press Start 2P'";
    ctx.fillText(beastMsg.text2, W/2, by+48);
 
    // Size indicator
    ctx.fillStyle = 'rgba(255,255,255,0.5)';
    ctx.font = "6px 'Press Start 2P'";
    ctx.fillText(`SIZE ×${beastMsg.scale}  —  ${RARITY_NAME[beastMsg.fish.rarity].toUpperCase()} CLASS`, W/2, by+62);
 
    ctx.restore();
    if(beastMsgTimer <= 0) beastMsg = null;
  }
 
  // Admin UI — always on top
  drawAdminUI(dt);
}
 
// ═══════════════════════════════════════════════════════
//  MAIN LOOP
// ═══════════════════════════════════════════════════════
function loop(ts){
  if(!gs.started) return;
  const dt=Math.min((ts-lastTs)/1000, 0.05);
  lastTs=ts;
  try{ update(dt); } catch(e){ console.error('update err',e); }
  try{ render(dt); } catch(e){ console.error('render err',e); }
  requestAnimationFrame(loop);
}
 
