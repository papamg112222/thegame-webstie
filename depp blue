    if(sc>=4) el.style.boxShadow=`0 0 8px ${RARITY_COL[c.fish.rarity]}66`;
 
    const fc=document.createElement('canvas');
    const previewSc=Math.min(2.0, 0.55+c.fish.rarity*0.22+Math.min(0.4,(sc-1)*0.15));
    fc.width=64; fc.height=54; fc.className='sell-item-canvas';
    const fctx=fc.getContext('2d');
    fctx.fillStyle='#001830'; fctx.fillRect(0,0,64,54);
