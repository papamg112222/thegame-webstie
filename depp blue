}
 
function onAdminInput(){
  const raw=document.getElementById('ac-input').value;
  refreshAdminCmds(raw);
  // Fish panel: show fish list whenever input contains a fish name or spawn command
  const lo=raw.toLowerCase();
  if(lo.startsWith('spawn fish ')){
    const nameQ=lo.slice(11).replace(/\s+\d+(\.\d+)?$/,'').trim();
    refreshFishList(nameQ);
  } else if(lo.includes('fish')||lo===''){
    refreshFishList('');
  } else {
    refreshFishList(raw);
  }
}
 
function execAdminCmd(raw){
  const parts=raw.trim().split(/\s+/);
  const lo=parts.map(p=>p.toLowerCase());
  let result='', ok=true;
 
  if(lo[0]==='set'&&lo[1]==='speed'){
    const v=parseFloat(lo[2])||5;
    gs.swimSpeed=Math.max(0.5,Math.min(500,v));
    result=`Speed → ${gs.swimSpeed}`;
  } else if(lo[0]==='set'&&lo[1]==='oxygen'){
    const v=parseInt(lo[2])||120;
    gs.maxOxy=Math.max(10,v); gs.curOxy=gs.maxOxy;
    result=`Oxygen → ${gs.maxOxy}s`;
  } else if(lo[0]==='set'&&lo[1]==='depth'){
    const v=parseInt(lo[2])||5000;
    gs.maxDepth=Math.max(100,v);
    result=`Max depth → ${gs.maxDepth}m`;
  } else if(lo[0]==='set'&&lo[1]==='coins'){
    const v=parseInt(lo[2])||9999;
    gs.coins=Math.max(0,v);
    result=`Coins → ${gs.coins} FC`;
  } else if(lo[0]==='set'&&lo[1]==='netsize'){
    const v=parseInt(lo[2])||50;
    gs.maxNet=Math.max(1,v);
    result=`Net size → ${gs.maxNet}`;
  } else if(lo[0]==='set'&&lo[1]==='luck'){
    const v=parseInt(lo[2])||100;
    gs.luck=Math.max(0,Math.min(100,v));
    result=`Luck → ${gs.luck}`;
  } else if(lo[0]==='spawn'&&lo[1]==='fish'){
    // Parse: spawn fish {name} {size} {depth}
    // last token = depth if numeric, second-to-last = size if numeric, rest = name
    const allRest=parts.slice(2);
    let fishName, fishSize=null, fishDepth=undefined;
    // Check if last token is a number (depth)
    const lastVal=parseFloat(allRest[allRest.length-1]);
    const secondLast=parseFloat(allRest[allRest.length-2]);
    if(!isNaN(lastVal)&&!isNaN(secondLast)&&allRest.length>=3){
      // "name size depth" — both last two are numbers
      fishDepth=Math.max(0,lastVal);
      fishSize=Math.max(0.1,secondLast);
      fishName=allRest.slice(0,-2).join(' ');
    } else if(!isNaN(lastVal)&&allRest.length>=2){
      // "name size" — last is size
      fishSize=Math.max(0.1,lastVal);
      fishName=allRest.slice(0,-1).join(' ');
    } else {
      fishName=allRest.join(' ');
    }
    const found=FISH.find(f=>f.name.toLowerCase()===fishName.toLowerCase())||
                FISH.find(f=>f.name.toLowerCase().includes(fishName.toLowerCase()));
    if(found){
      if(!diver.underwater){ diver.y=SURF_Y+80; }
      const sc=fishSize!==null?fishSize:RARITY_SCALE[found.rarity];
      spawnFish(found, sc, fishDepth);
      result=`Spawned ${found.name} size×${sc.toFixed(1)}${fishDepth!==undefined?' at '+fishDepth+'m depth':''}`;
    } else { ok=false; result=`Fish not found: "${fishName}"`; }
  } else if(lo[0]==='clear'&&lo[1]==='fish'){
    liveFish=[]; result='All fish cleared';
  } else if(lo[0]==='max'&&lo[1]==='upgrades'){
    for(const id of Object.keys(UPGRADE_CAPS)){
      gs.upgrades[id]=UPGRADE_CAPS[id].maxLevel;
      const item=Object.values(SHOP_DATA).flat().find(i=>i.id===id);
      if(item) applyUpgrade(id,UPGRADE_CAPS[id].maxLevel,item);
    }
    result='All upgrades maxed!';
  } else if(lo[0]==='reset'&&lo[1]==='upgrades'){
    gs.upgrades={}; gs.swimSpeed=2.2; gs.sinkSpeed=2.5; gs.swimBoost=1;
    gs.maxNet=5; gs.maxOxy=60; gs.curOxy=60; gs.luck=0; gs.luckMythic=0;
    gs.catchRadius=90; gs.maxDepth=600; gs.valueBoost=1;
    result='All upgrades reset';
  } else if(lo[0]==='god'&&lo[1]==='mode'){
    gs.swimSpeed=25; gs.sinkSpeed=25; gs.swimBoost=3;
    gs.maxNet=9999; gs.netCount=0; gs.maxOxy=999999; gs.curOxy=999999;
    gs.luck=100; gs.luckMythic=5; gs.catchRadius=300;
    gs.maxDepth=99999; gs.valueBoost=10; gs.coins=999999;
    result='GOD MODE ON — all stats maxed!';
  } else if(lo[0]==='teleport'&&lo[1]==='surface'){
    diver.y=SURF_Y-2; camY=0; result='Teleported to surface';
  } else if(lo[0]==='teleport'&&lo[1]==='deep'){
    diver.y=SURF_Y+5000/PX_PER_M; camY=Math.max(0,diver.y-H*0.5);
    result='Teleported to 5000m';
  } else {
    ok=false; result=`Unknown command: "${raw}"`;
  }
 
  const resEl=document.getElementById('ac-result');
  resEl.textContent=(ok?'✓  ':'✗  ')+result;
  resEl.style.color=ok?'#00ff88':'#ff4444';
  document.getElementById('ac-input').value='';
  onAdminInput();
}
 
