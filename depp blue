// ─────────────────────────────────────────────────────────────────
// SQUID / OCTOPUS — detailed mantle + animated tentacles
// ─────────────────────────────────────────────────────────────────
function drawSquid(ctx,s,t,body,fin){
  const pulse=Math.sin(t*3.5), b2=lighter(body,25), b3=darker(body,30);
  // Mantle (torpedo-shaped head)
  pxArc(ctx,0,-10*s,5*s,10*s,body);
  pxRect(ctx,-5*s,-12*s,10*s,14*s,body);
  pxArc(ctx,0,-12*s,5*s,4*s,lighter(b2,10));
  pxRect(ctx,-3*s,-14*s,6*s,4*s,b2);
  // Mantle fin (lateral)
  pxRect(ctx,-8*s,-10*s,4*s,8*s,P(fin[0],fin[1],fin[2],180));
  pxRect(ctx, 4*s,-10*s,4*s,8*s,P(fin[0],fin[1],fin[2],180));
  // Chromatophore spots
  for(const [px,py,r] of [[-3,-8,2],[2,-6,1.5],[-1,-11,1.5],[3,-9,1]]){
    pxArc(ctx,px*s,py*s,r*s,r*s,darker(body,30));
  }
  // Collar
  pxRect(ctx,-5*s,-2*s,10*s,3*s,b3);
  // Arms (8 + 2 tentacles, wavy)
  const armData=[[0,16],[3,18],[-3,18],[5,15],[-5,15],[7,12],[-7,12],[2,13],[-2,13],[4,14]];
  armData.forEach(([ax,aLen],i)=>{
    const wave=Math.sin(t*2.5+i*0.6)*s*3;
    const aCol=i<2?lighter(body,15):body; // longer feeding tentacles lighter
    pxRect(ctx,(ax-s)*s, 1*s,2*s,(aLen+wave)*s,aCol);
    // Sucker dots along longer arms
    if(aLen>14) for(let j=0;j<3;j++){
      pxRect(ctx,ax*s,(4+j*4)*s,s,s,P(255,255,255,60));
    }
  });
  // Eyes (large, alien)
  pxArc(ctx,-3*s,-6*s,4*s,4*s,P(180,220,255,230));
  pxArc(ctx,-3*s,-6*s,2.5*s,2.5*s,P(0,0,0));
  pxRect(ctx,-4*s,-7*s,s,s,P(255,255,255,220));
  pxArc(ctx,3*s,-6*s,4*s,4*s,P(180,220,255,230));
  pxArc(ctx,3*s,-6*s,2.5*s,2.5*s,P(0,0,0));
}
 
// ─────────────────────────────────────────────────────────────────
// ANGLERFISH — nightmare deep-sea horror, highly detailed
// ─────────────────────────────────────────────────────────────────
function drawAngler(ctx,s,t,body,fin){
  const jawGape=Math.abs(Math.sin(t*1.8))*s*4;
