let diverAnimT = 0; // accumulated animation time
 
function drawDiver(){
  const sx = diver.x;
  const sy = screenY(diver.y);
  if(sy < -80 || sy > H + 80) return;
 
  const underwater = diver.underwater;
  const moving = diver._moving;
  const t = diverAnimT;
 
  ctx.save();
  ctx.translate(Math.floor(sx), Math.floor(sy));
  if(!diver.facingR) ctx.scale(-1, 1);
 
  // ── shared colours ──
  const SUIT    = P(20, 55, 130);
  const SUIT_LT = P(35, 80, 180);
  const SUIT_HL = P(60, 110, 220);
  const HELM    = P(30, 70, 160);
  const VISOR   = P(100, 190, 255, 200);
  const VISOR_S = P(200, 235, 255, 160);
  const TANK    = P(55, 75, 110);
  const TANK_LT = P(90, 110, 145);
  const FIN_COL = P(0, 185, 105);
  const FIN_DRK = P(0, 140, 75);
  const HOSE    = P(50, 70, 100);
 
  // ─────────────────────────────────────────
  if(!underwater){
    // ══ WALK ANIMATION ══
    // Frame oscillation: 8-frame walk cycle
    const walkCycle = moving ? Math.sin(t * 8) : 0;
    const walkCycle2 = moving ? Math.sin(t * 8 + Math.PI) : 0;
    const bobY = moving ? Math.abs(Math.sin(t * 8)) * -1.5 : 0; // slight bob up
 
    ctx.translate(0, Math.round(bobY));
 
    // ── LEGS (walk cycle) ──
    // Left leg
    const lLegOff = Math.round(walkCycle * 5);
    pxRect(ctx, -7, 10, 7, 13 + lLegOff, SUIT);
    pxRect(ctx, -9, 22 + lLegOff, 11, 4, SUIT_LT); // boot
    // Right leg
    const rLegOff = Math.round(walkCycle2 * 5);
    pxRect(ctx, 1, 10, 7, 13 + rLegOff, SUIT);
    pxRect(ctx, -1, 22 + rLegOff, 11, 4, SUIT_LT); // boot
 
    // ── BODY ──
    pxRect(ctx, -8, -16, 17, 27, SUIT);
    pxRect(ctx, -6, -14, 5, 22, SUIT_LT); // left panel
    pxRect(ctx, -6, -14, 13, 3, SUIT_HL); // chest stripe
 
    // ── ARMS (swing opposite legs) ──
    const lArmSwing = Math.round(walkCycle2 * 6);
    const rArmSwing = Math.round(walkCycle * 6);
    pxRect(ctx, -13, -12 + lArmSwing, 6, 16, SUIT);
    pxRect(ctx, 8,  -12 + rArmSwing, 6, 16, SUIT);
    // Gloves
    pxRect(ctx, -14, 3 + lArmSwing, 7, 5, SUIT_LT);
    pxRect(ctx, 8, 3 + rArmSwing, 7, 5, SUIT_LT);
 
    // ── TANK ──
    pxRect(ctx, 7, -14, 7, 22, TANK);
    pxRect(ctx, 9, -15, 4, 5, TANK_LT);
    pxRect(ctx, 11, 7, 3, 7, HOSE);
 
    // ── HELMET ──
    pxRect(ctx, -9, -34, 19, 20, HELM);
    pxRect(ctx, -7, -36, 15, 4, HELM);
    pxRect(ctx, -5, -38, 11, 3, HELM);
    // Visor
    pxRect(ctx, -6, -33, 12, 11, VISOR);
    pxRect(ctx, -4, -32, 8, 8, VISOR_S);
    pxRect(ctx, -5, -32, 3, 3, P(255,255,255,200)); // shine
    // Helmet ring
    pxRect(ctx, -9, -17, 19, 4, P(50, 80, 130));
 
  } else {
    // ══ SWIM ANIMATION ══
    // Body tilts slightly in direction of vertical movement
    const vertMove = diver._dy || 0;
    const tiltAngle = vertMove * 0.18;
    ctx.rotate(tiltAngle);
 
    // Kick cycle for fins (fast kick)
    const kick = Math.sin(t * 10);
    const kick2 = Math.sin(t * 10 + Math.PI);
    const armPull = Math.sin(t * 6); // arms pull back and forward
 
    // ── FINS (kicking hard) ──
    // Left fin
    const lFinRot = kick * 0.4;
    ctx.save();
    ctx.translate(-5, 18);
    ctx.rotate(lFinRot);
    pxRect(ctx, -3, 0, 7, 14, FIN_COL);
    pxRect(ctx, -8, 10, 16, 5, FIN_COL); // fin blade
    pxRect(ctx, -10, 13, 18, 3, FIN_DRK);
    ctx.restore();
 
    // Right fin
    const rFinRot = kick2 * 0.4;
    ctx.save();
    ctx.translate(5, 18);
    ctx.rotate(rFinRot);
    pxRect(ctx, -4, 0, 7, 14, FIN_COL);
    pxRect(ctx, -8, 10, 16, 5, FIN_COL);
    pxRect(ctx, -10, 13, 18, 3, FIN_DRK);
    ctx.restore();
 
    // ── LEGS ──
    pxRect(ctx, -7, 9, 7, 10, SUIT);
    pxRect(ctx, 1, 9, 7, 10, SUIT);
 
    // ── BODY ──
    pxRect(ctx, -8, -16, 17, 26, SUIT);
    pxRect(ctx, -6, -14, 5, 20, SUIT_LT);
    pxRect(ctx, -6, -14, 13, 3, SUIT_HL);
 
    // ── ARMS (pulling through water) ──
    // Arms extend forward when swimming
    const lArmX = Math.round(armPull * 4);
    const rArmX = Math.round(-armPull * 4);
    // Left arm sweeps forward
    ctx.save();
    ctx.translate(-13, -10);
    ctx.rotate(-0.4 + armPull * 0.4);
    pxRect(ctx, 0, 0, 6, 18, SUIT);
    pxRect(ctx, -1, 14, 8, 5, SUIT_LT);
    ctx.restore();
    // Right arm sweeps back
    ctx.save();
    ctx.translate(8, -10);
    ctx.rotate(0.4 + armPull * 0.4);
    pxRect(ctx, 0, 0, 6, 18, SUIT);
    pxRect(ctx, -1, 14, 8, 5, SUIT_LT);
    ctx.restore();
 
    // ── TANK ──
    pxRect(ctx, 7, -14, 7, 22, TANK);
    pxRect(ctx, 9, -15, 4, 5, TANK_LT);
    pxRect(ctx, 11, 7, 3, 7, HOSE);
 
    // ── HELMET ──
    pxRect(ctx, -9, -34, 19, 20, HELM);
    pxRect(ctx, -7, -36, 15, 4, HELM);
    pxRect(ctx, -5, -38, 11, 3, HELM);
    pxRect(ctx, -6, -33, 12, 11, VISOR);
    pxRect(ctx, -4, -32, 8, 8, VISOR_S);
    pxRect(ctx, -5, -32, 3, 3, P(255,255,255,200));
    pxRect(ctx, -9, -17, 19, 4, P(50, 80, 130));
 
    // Bubbles from helmet
    if(Math.random() < 0.07){
      bubbles.push({
        x: sx + (diver.facingR ? 8 : -8),
        y: diver.y - 34,
        r: 2 + Math.random() * 2.5,
        vy: -0.8 - Math.random() * 0.7,
        life: 1,
        vx: (Math.random() - 0.5) * 0.4
      });
    }
  }
 
  ctx.restore();
 
  // ── CATCH RING (glowing, pulsing) ── drawn in world space ──
  if(underwater){
    const rSx = sx;
    const rSy = sy;
    const R = gs.catchRadius;
    const pulse = (Math.sin(Date.now() * 0.004) + 1) * 0.5; // 0→1
    const alpha1 = 0.18 + pulse * 0.22;
    const alpha2 = 0.55 + pulse * 0.35;
    const ringColor = gs.netCount >= gs.maxNet ? '255,80,80' : '0,220,255';
 
    // Outer soft glow ring
    ctx.save();
    ctx.beginPath();
    ctx.arc(rSx, rSy, R + 4, 0, Math.PI * 2);
    ctx.strokeStyle = `rgba(${ringColor},${alpha1 * 0.5})`;
    ctx.lineWidth = 8;
    ctx.stroke();
 
    // Main ring
    ctx.beginPath();
    ctx.arc(rSx, rSy, R, 0, Math.PI * 2);
    ctx.strokeStyle = `rgba(${ringColor},${alpha2})`;
    ctx.lineWidth = 2;
    ctx.setLineDash([6, 4]);
    ctx.lineDashOffset = -(Date.now() * 0.04 % 10);
    ctx.stroke();
    ctx.setLineDash([]);
 
    // Inner ring (smaller, faster pulse)
    const pulse2 = (Math.sin(Date.now() * 0.007 + 1) + 1) * 0.5;
    ctx.beginPath();
    ctx.arc(rSx, rSy, R * 0.55, 0, Math.PI * 2);
    ctx.strokeStyle = `rgba(${ringColor},${0.12 + pulse2 * 0.15})`;
    ctx.lineWidth = 1.5;
    ctx.stroke();
 
    ctx.restore();
  }
}
 
