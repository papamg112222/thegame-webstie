  const sorted=[...FISH].sort((a,b)=>b.value-a.value);
 
  document.getElementById('encycTotalLabel').textContent=
    FISH.length+' SPECIES  |  '+Object.keys(fishCaughtStats).length+' DISCOVERED';
 
  sorted.forEach((fish,idx)=>{
    const caught=fishCaughtStats[fish.id];
    const row=document.createElement('div');
    row.className='enc-row'+(encycSelectedId===fish.id?' active':'');
    row.dataset.id=fish.id;
 
    // Mini fish canvas
    const fc=document.createElement('canvas');
