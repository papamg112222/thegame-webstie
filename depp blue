    pxRect(ctx,(-9+c*5)*s,(-7+r*4)*s,3*s,2*s,P(255,255,255,18));
  }
}
 
// ─────────────────────────────────────────────────────────────────
// MASTER DISPATCHER
// ─────────────────────────────────────────────────────────────────
function drawPixelFish(ctx,x,y,fr,s,t,body,fin,eye,shape,glowCol){
  ctx.save();
  ctx.translate(Math.floor(x),Math.floor(y));
  if(fr) ctx.scale(-1,1);
  if(glowCol){ctx.shadowColor=glowCol;ctx.shadowBlur=20+Math.sin(t*2.2)*8;}
  const belly=lighter(body,50);
  switch(shape){
    case 'small':      drawSmall(ctx,s,t,body,fin); break;
    case 'round':      drawRound(ctx,s,t,body,fin,true); break;
    case 'roundPlain': drawRoundPlain(ctx,s,t,body,fin); break;
    case 'eel':        drawEel(ctx,s,t,body,fin); break;
    case 'ray':        drawRay(ctx,s,t,body,fin); break;
    case 'shark':      drawShark(ctx,s,t,body,fin); break;
    case 'angel':      drawAngel(ctx,s,t,body,fin); break;
    case 'squid':      drawSquid(ctx,s,t,body,fin); break;
    case 'angler':     drawAngler(ctx,s,t,body,fin); break;
    case 'dragon':     drawDragon(ctx,s,t,body,fin); break;
    case 'whale':      drawWhale(ctx,s,t,body,fin); break;
    case 'big':        drawBig(ctx,s,t,body,fin,belly); break;
    default:           drawStandard(ctx,s,t,body,fin,belly); break;
  }
  ctx.shadowBlur=0;
  ctx.restore();
}
