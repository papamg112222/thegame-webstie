    drawPixelFish(fctx,32,28,true,previewSc,Date.now()*0.001,c.fish.body,c.fish.fin,c.fish.eye||P(255,255,255),c.fish.shape);
    fctx.shadowBlur=0;
    el.appendChild(fc);
