  pxRect(ctx,7*s,-18*s,6*s,5*s,lighter(fin,32));
  // Left pectoral fin (huge)
  pxRect(ctx,-22*s,10*s,20*s,16*s,b3);
  pxRect(ctx,-20*s,11*s,16*s,12*s,darker(b3,15));
  // Right pectoral hint
  pxRect(ctx,-20*s,-18*s,16*s,6*s,b3);
  // Head — massive rostrum
  pxRect(ctx,-30*s,-11*s,9*s,22*s,b2);
  pxRect(ctx,-36*s,-7*s,8*s,15*s,b2); // jaw
  pxRect(ctx,-40*s,-4*s,6*s,9*s,b2); // tip
  // Mouth line (curved smile)
  pxRect(ctx,-40*s, 3*s,14*s,3*s,darker(belly,60));
  // Baleen plates (hint inside mouth)
  for(let i=0;i<7;i++) pxRect(ctx,(-39+i*2)*s,0,s,5*s,lighter(belly,40));
  // Blowhole
  pxRect(ctx,-18*s,-14*s,5*s,3*s,darker(body,50));
  pxRect(ctx,-16*s,-16*s,3*s,3*s,darker(body,60));
  // Eye — tiny relative to body, with eyelid detail
  pxRect(ctx,-22*s,-8*s,8*s,8*s,P(255,255,255));
  pxRect(ctx,-20*s,-6*s,5*s,5*s,P(10,10,30));
  pxRect(ctx,-22*s,-8*s,2*s,2*s,P(255,255,255,220));
  pxRect(ctx,-22*s,-9*s,8*s,2*s,darker(body,40)); // upper eyelid
  // Scars (battle with giant squid)
  pxLine(ctx,-10*s,-12*s,-4*s,-6*s,b3,s*2);
  pxLine(ctx, 2*s,-11*s, 8*s,-7*s,b3,s*1.5);
  pxLine(ctx,12*s,-9*s,16*s,-5*s,b3,s);
  // Barnacle clusters
  for(const [bx,by] of [[-15,-10],[-8,-11],[1,-10],[10,-9],[3,7],[-5,8]]){
    pxArc(ctx,bx*s,by*s,s*2,s*1.5,darker(body,45));
    pxArc(ctx,bx*s,by*s,s,s,darker(body,55));
  }
  // Remoras (tiny hitchhikers)
  pxRect(ctx,5*s,10*s,8*s,2*s,P(80,80,90));
  pxRect(ctx,-5*s,-10*s,6*s,2*s,P(80,80,90));
}
 
