}
 
// ─────────────────────────────────────────────────────────────────
// SEA DRAGON — massive mythic serpent with wings and fire
// ─────────────────────────────────────────────────────────────────
function drawDragon(ctx,s,t,body,fin){
  const segs=12, b2=lighter(body,25), b3=darker(body,35), glowC=fin;
  const gStr=`rgba(${fin[0]},${fin[1]},${fin[2]},0.7)`;
  // Body — sinuous serpent
  for(let i=0;i<segs;i++){
    const ox=(-segs/2+i)*5.5*s;
    const oy=Math.sin(t*1.8+i*0.6)*5*s;
    const h=i===0?12*s:i===segs-1?5*s:i<3?10*s:8*s;
    // Alternating scale rows
    pxRect(ctx,ox,oy-h/2,5.5*s,h,i%2===0?body:b2);
    pxRect(ctx,ox,oy-h/2,5.5*s,h*0.2,b3); // dorsal dark
    pxRect(ctx,ox,oy+h*0.35,5.5*s,h*0.25,lighter(body,40)); // ventral plates
    // Scale markings
    pxRect(ctx,ox+s,oy-h/4,s,h/2,P(255,255,255,15));
    // Glowing dorsal spines every 2 segs
    if(i%2===0&&i>0&&i<segs-1){
      ctx.shadowColor=gStr; ctx.shadowBlur=8*s;
      pxRect(ctx,ox+s,oy-h/2-5*s,3*s,5*s,fin);
      pxRect(ctx,ox+2*s,oy-h/2-6*s,s,2*s,lighter(fin,60));
      ctx.shadowBlur=0;
    }
  }
  // Large side wings (mid-body)
  const wingY=Math.sin(t*1.8+4*0.6)*5*s;
  ctx.shadowColor=gStr; ctx.shadowBlur=6*s;
  pxRect(ctx,(-segs/2+4)*5.5*s, wingY-20*s,16*s,16*s,darker(fin,30));
  pxRect(ctx,(-segs/2+4)*5.5*s, wingY+ 8*s,16*s,16*s,darker(fin,30));
  pxRect(ctx,(-segs/2+4)*5.5*s, wingY-22*s,8*s,4*s,fin); // membrane edge
  pxRect(ctx,(-segs/2+4)*5.5*s, wingY+22*s,8*s,4*s,fin);
  ctx.shadowBlur=0;
  // Head — massive horned dragon head
  const hx=(-segs/2)*5.5*s-10*s;
  const hy=Math.sin(t*1.8)*5*s;
  pxRect(ctx,hx,hy-9*s,14*s,18*s,lighter(b2,10));
  pxRect(ctx,hx-7*s,hy-4*s,9*s,10*s,lighter(b2,10)); // lower jaw / snout
  // Large curved horns
  ctx.shadowColor=gStr; ctx.shadowBlur=10*s;
  pxRect(ctx,hx+2*s,hy-17*s,4*s,9*s,fin);
  pxRect(ctx,hx+8*s,hy-14*s,4*s,7*s,fin);
  pxRect(ctx,hx+1*s,hy-18*s,3*s,3*s,lighter(fin,50));
  ctx.shadowBlur=0;
  // Beard/chin spines
  pxRect(ctx,hx-5*s,hy+4*s,3*s,6*s,P(fin[0],fin[1],fin[2],180));
  pxRect(ctx,hx-3*s,hy+6*s,2*s,5*s,P(fin[0],fin[1],fin[2],140));
  // Fangs
  for(let i=0;i<4;i++) pxRect(ctx,(hx-5+i*3)*s,hy+4*s,s*1.5,5*s,P(240,240,200));
  for(let i=0;i<3;i++) pxRect(ctx,(hx-4+i*3)*s,hy-1*s,s*1.5,4*s,P(230,230,190));
  // Flame breath
  const fl=Math.sin(t*6);
  if(fl>0.2){
    ctx.shadowColor='#ff8800'; ctx.shadowBlur=12*s;
    pxRect(ctx,hx-16*s,hy-4*s,8*s,5*s,P(255,160,0));
    pxRect(ctx,hx-22*s,hy-3*s,7*s,3*s,P(255,100,0));
    pxRect(ctx,hx-26*s,hy-2*s,5*s,2*s,P(255,50,0));
    pxRect(ctx,hx-28*s,hy-1*s,3*s,s,P(200,30,0));
    ctx.shadowBlur=0;
  }
  // Slitted eyes (glowing)
  ctx.shadowColor=gStr; ctx.shadowBlur=6*s;
  pxArc(ctx,hx+4*s,hy-4*s,4*s,4*s,P(255,220,0,230));
  ctx.shadowBlur=0;
  pxRect(ctx,hx+3*s,hy-6*s,2*s,6*s,P(0,0,0)); // vertical slit pupil
  pxRect(ctx,hx+3*s,hy-5*s,s,s,P(255,255,255,200));
  // Tail — whip-like with glowing tip
  const tx=(segs/2)*5.5*s, ty=Math.sin(t*2.2+segs*0.6)*5*s;
  ctx.shadowColor=gStr; ctx.shadowBlur=14*s;
  pxRect(ctx,tx+Math.sin(t*3)*s*4,ty-3*s,6*s,6*s,fin);
  pxRect(ctx,tx+Math.sin(t*3)*s*4+s,ty-s,4*s,2*s,lighter(fin,60));
  ctx.shadowBlur=0;
}
 
