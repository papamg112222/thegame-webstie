function drawShopBg(){
  const c=document.getElementById('shopBgC');
  const cx=c.getContext('2d');
  const W2=c.width, H2=c.height;
  // Wood base
  const g=cx.createLinearGradient(0,0,W2,H2);
  g.addColorStop(0,'#3d1f00'); g.addColorStop(0.5,'#5c2e08'); g.addColorStop(1,'#3d1f00');
  cx.fillStyle=g; cx.fillRect(0,0,W2,H2);
  // Grain
  cx.strokeStyle='rgba(0,0,0,0.12)'; cx.lineWidth=1;
  for(let y=0;y<H2;y+=6){cx.beginPath();cx.moveTo(0,y);cx.lineTo(W2,y);cx.stroke();}
  cx.strokeStyle='rgba(255,255,255,0.03)';
  for(let x=0;x<W2;x+=40){cx.beginPath();cx.moveTo(x,0);cx.lineTo(x,H2);cx.stroke();}
  // Knots
  for(const [kx,ky] of [[120,200],[350,380],[600,150],[780,420]]){
    cx.strokeStyle='rgba(0,0,0,0.2)'; cx.lineWidth=2;
    cx.beginPath(); cx.ellipse(kx,ky,14,10,0.3,0,Math.PI*2); cx.stroke();
    cx.strokeStyle='rgba(0,0,0,0.1)'; cx.lineWidth=1;
    cx.beginPath(); cx.ellipse(kx,ky,8,5,0.3,0,Math.PI*2); cx.stroke();
  }
}
 
function drawSellBg(){
  const c=document.getElementById('sellBgC');
  const cx=c.getContext('2d');
  const W2=c.width, H2=c.height;
  const g=cx.createLinearGradient(0,0,0,H2);
  g.addColorStop(0,'#000a1a'); g.addColorStop(0.5,'#001a38'); g.addColorStop(1,'#000a1a');
  cx.fillStyle=g; cx.fillRect(0,0,W2,H2);
  // Waves
  cx.strokeStyle='rgba(0,100,200,0.08)'; cx.lineWidth=2;
  for(let y=0;y<H2;y+=20){
    cx.beginPath();
    for(let x=0;x<W2;x+=4){
      const wy=y+Math.sin(x/30+y/20)*4;
      if(x===0)cx.moveTo(x,wy); else cx.lineTo(x,wy);
    }
    cx.stroke();
  }
  // Bubbles bg
  cx.fillStyle='rgba(0,150,255,0.04)';
  for(const [bx,by,br] of [[80,100,30],[200,300,20],[500,200,40],[700,400,25],[350,450,15]]){
    cx.beginPath(); cx.arc(bx,by,br,0,Math.PI*2); cx.fill();
  }
}
 
